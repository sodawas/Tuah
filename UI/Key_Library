        { icon = ICONS.shield, head = "Secure",        sub = "HWID & account protection" },
        { icon = ICONS.bolt,   head = "Fast updates",  sub = "Always latest features" },
        { icon = ICONS.star,   head = appTitle .. "+", sub = "Skip keys, unlock perks" },
    }

    local PillRow = New("Frame", {
        Parent = CI, Position = UDim2.new(0,0,0,244),
        -- Height exactly 48; width = 3*pillW + 2*6 ≤ pillAvail
        Size = UDim2.new(0, pillW*3+12, 0, 48),
        BackgroundTransparency = 1, ZIndex = 14,
    })
