    -- ── Verify button ──────────────────────────────────────────────────────
    local VerifyBtn = New("Frame", {
        Parent = CI, Position = UDim2.new(0,0,0,112),
        Size = UDim2.new(1,0,0,36),
        BackgroundColor3 = T.Highlight, ZIndex = 14, ClipsDescendants = true,
    })
    Corner(VerifyBtn, 6)

    local VerifyFill = New("Frame", {
        Parent = VerifyBtn, Size = UDim2.new(0,0,1,0),
        BackgroundColor3 = T.Success, ZIndex = 14,
    })
    Corner(VerifyFill, 6)

    local VerifyLabel = New("TextLabel", {
        Parent = VerifyBtn, Size = UDim2.new(1,0,1,0),
