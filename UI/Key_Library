        Parent = Sidebar, AnchorPoint = Vector2.new(.5,0),
        Position = UDim2.new(.5,0,0,63),
        Size = UDim2.new(.55,0,0,1),
        BackgroundColor3 = T.Border, ZIndex = 12,
    })

