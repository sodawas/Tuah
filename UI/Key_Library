local function New(class, props)
    local i = Instance.new(class)
    for k, v in next, props do i[k] = v end
    pcall(function() i.BorderSizePixel = 0 end)
    return i
end
local function Corner(p, r) New("UICorner", {Parent=p, CornerRadius=UDim.new(0, r or 8)}) end
local function Stroke(p, col, thick)
    return New("UIStroke", {
        Parent=p, Color=col or T.Border, Thickness=thick or 1,
        LineJoinMode=Enum.LineJoinMode.Round,
        ApplyStrokeMode=Enum.ApplyStrokeMode.Border,
    })
end
local function Pad(p, l, r, t, b)
    New("UIPadding", {
        Parent=p,
        PaddingLeft=UDim.new(0,l), PaddingRight=UDim.new(0,r),
        PaddingTop=UDim.new(0,t),  PaddingBottom=UDim.new(0,b),
    })
end
local function TW(i, ti, pr) TweenService:Create(i, ti, pr):Play() end
local EI = TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

local fsOk = (type(writefile) == "function" and type(readfile) == "function")
local function saveKey(k)
    if not fsOk then return end
    pcall(function() writefile("_jnk.txt", k) end)
end
local function loadKey()
    if not fsOk then return nil end
    local ok, v = pcall(function() return readfile("_jnk.txt") end)
    return (ok and type(v) == "string" and v ~= "") and v or nil
end
local function clearKey()
    if not fsOk then return end
    pcall(function() delfile("_jnk.txt") end)
end

local function getExecutor() return (identifyexecutor and identifyexecutor()) or "Unknown" end
local function getTime()     return (os.date and os.date("%I:%M %p")) or "N/A" end
local function getGame()
    local ok, n = pcall(function()
        return game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
    end)
    return ok and n or tostring(game.PlaceId)
end

-- fallback idk
function validateKeyHTTP(junkie, key)
    if junkie and junkie.check_key then
        local ok, r = pcall(function() return junkie.check_key(key) end)
        if not ok or not r then return false end
        if type(r) == "boolean" then return r end
        if type(r) == "table" then
            return r.valid == true
                or r.message == "KEY_VALID"
                or r.message == "KEYLESS"
        end
        return false
    end
    return key ~= nil and key ~= ""
end

