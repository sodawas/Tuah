    end

    for _, g in ipairs(keyGames)  do AddGameRow(KeyList,  g, true)  end
    for _, g in ipairs(freeGames) do AddGameRow(FreeList, g, false) end

    -- ════════════════════════════════════════════════════════════════
    -- PAGE 3 — INFO
    -- ════════════════════════════════════════════════════════════════
    local InfoPage = MakePage()
    New("UIPadding", { Parent = InfoPage,
        PaddingLeft = UDim.new(0, 24), PaddingRight  = UDim.new(0, 24),
        PaddingTop  = UDim.new(0, 20), PaddingBottom = UDim.new(0, 20),
    })

    local function InfoRow(yOff, label, value)
        New("TextLabel", {
            Parent               = InfoPage,
            Position             = UDim2.new(0, 0, 0, yOff),
            Size                 = UDim2.new(.45, 0, 0, 22),
            BackgroundTransparency = 1,
            Text                 = label,
            TextColor3           = T.Subtext,
            FontFace             = FONT_BOLD,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Left,
            ZIndex               = 13,
        })
        New("TextLabel", {
            Parent               = InfoPage,
            Position             = UDim2.new(.45, 0, 0, yOff),
            Size                 = UDim2.new(.55, 0, 0, 22),
            BackgroundTransparency = 1,
            Text                 = value,
            TextColor3           = T.Text,
            FontFace             = FONT,
            TextSize             = 11,
            TextXAlignment       = Enum.TextXAlignment.Left,
            ZIndex               = 13,
        })
        New("Frame", {
            Parent           = InfoPage,
            Position         = UDim2.new(0, 0, 0, yOff + 22),
            Size             = UDim2.new(1, 0, 0, 1),
            BackgroundColor3 = T.Border,
            ZIndex           = 13,
        })
    end

    New("TextLabel", {
        Parent               = InfoPage,
        Size                 = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        Text                 = appTitle .. "  ·  Information",
        TextColor3           = T.Title,
        FontFace             = FONT_BOLD,
        TextSize             = 15,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 13,
    })

    InfoRow(34,  "Version",      "v5.0")
    InfoRow(60,  "Key Provider", "Junkie (jnkie.com)")
    InfoRow(86,  "Key Format",   "buried-XXXX-XXXX-XXXX-XXX")
    InfoRow(112, "Key Storage",  fsOk and "Auto-saved locally" or "Session only")
    InfoRow(138, "Support",      "discord.gg/lotus")

    -- ── Sidebar tab buttons ────────────────────────────────────────────────
    local pages = { verify = VerifyPage, games = GamesPage, info = InfoPage }
    local BTN_Y_START = 80
    local BTN_SPACING = 60

    local function SwitchTab(id)
        if activeTab == id then return end
        activeTab = id
        for tid, frame in pairs(pages) do
            frame.Visible = (tid == id)
        end
        for tid, btn in pairs(tabBtns) do
            local isActive = (tid == id)
            TW(btn.bg, EI, {
                BackgroundColor3 = isActive and T.Accent or RGB(0,0,0),
                BackgroundTransparency = isActive and 0 or 1,
            })
            TW(btn.icon, EI, { TextColor3 = isActive and T.Highlight or T.Subtext })
            TW(btn.lbl,  EI, { TextColor3 = isActive and T.Highlight or T.Subtext })
            tabIndicators[tid].Visible = isActive
        end
    end

    for idx, tabInfo in ipairs(TAB_ICONS) do
        local yPos = BTN_Y_START + (idx - 1) * BTN_SPACING

        -- active indicator (left accent bar)
        local indicator = New("Frame", {
            Parent           = Sidebar,
            Position         = UDim2.new(0, 0, 0, yPos + 6),
            Size             = UDim2.new(0, 2, 0, 30),
            BackgroundColor3 = T.Highlight,
            ZIndex           = 14,
            Visible          = (tabInfo.id == activeTab),
        })
        Corner(indicator, 2)
        tabIndicators[tabInfo.id] = indicator

        -- button background (pill)
        local bg = New("Frame", {
            Parent               = Sidebar,
            AnchorPoint          = Vector2.new(.5, 0),
            Position             = UDim2.new(.5, 0, 0, yPos),
            Size                 = UDim2.new(0, 46, 0, 42),
            BackgroundColor3     = tabInfo.id == activeTab and T.Accent or RGB(0,0,0),
            BackgroundTransparency = tabInfo.id == activeTab and 0 or 1,
            ZIndex               = 13,
        })
        Corner(bg, 8)

        local iconLbl = New("TextLabel", {
            Parent               = bg,
            AnchorPoint          = Vector2.new(.5, 0),
            Position             = UDim2.new(.5, 0, 0, 6),
            Size                 = UDim2.new(1, 0, 0, 18),
            BackgroundTransparency = 1,
            Text                 = tabInfo.icon,
            TextColor3           = tabInfo.id == activeTab and T.Highlight or T.Subtext,
            TextSize             = 16,
            ZIndex               = 14,
        })

        local lblLbl = New("TextLabel", {
            Parent               = bg,
            AnchorPoint          = Vector2.new(.5, 1),
            Position             = UDim2.new(.5, 0, 1, -5),
            Size                 = UDim2.new(1, 0, 0, 11),
            BackgroundTransparency = 1,
            Text                 = tabInfo.label,
            TextColor3           = tabInfo.id == activeTab and T.Highlight or T.Subtext,
            FontFace             = FONT_BOLD,
            TextSize             = 8,
            ZIndex               = 14,
        })

        local clickBtn = New("TextButton", {
            Parent               = bg,
            Size                 = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text                 = "",
            ZIndex               = 15,
        })

        tabBtns[tabInfo.id] = { bg = bg, icon = iconLbl, lbl = lblLbl }

        clickBtn.MouseButton1Up:Connect(function() SwitchTab(tabInfo.id) end)
        clickBtn.MouseEnter:Connect(function()
            if activeTab ~= tabInfo.id then
                TW(bg,      EI, { BackgroundColor3 = T.Tone, BackgroundTransparency = 0 })
                TW(iconLbl, EI, { TextColor3 = T.Text })
                TW(lblLbl,  EI, { TextColor3 = T.Text })
            end
        end)
        clickBtn.MouseLeave:Connect(function()
            if activeTab ~= tabInfo.id then
                TW(bg,      EI, { BackgroundTransparency = 1 })
                TW(iconLbl, EI, { TextColor3 = T.Subtext })
                TW(lblLbl,  EI, { TextColor3 = T.Subtext })
            end
        end)
    end

    -- ── State machine ──────────────────────────────────────────────────────
    local processing = false

    local function SetStatus(state)
        if state == "idle" then
            VerifyLabel.Text       = "Verify Key  →"
            VerifyLabel.TextColor3 = T.Title
            HintLabel.Text         = ""
            TW(VerifyBtn,  EI, { BackgroundColor3 = T.Highlight })
            TW(StatusFill, EI2, { Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = T.Highlight })

        elseif state == "loading" then
            TW(VerifyBtn, EI, { BackgroundColor3 = T.Hover })

        elseif state == "success" then
            VerifyLabel.Text       = "Verified  ✓"
            VerifyLabel.TextColor3 = T.Background
            HintLabel.Text         = ""
            TW(VerifyBtn,  EI,  { BackgroundColor3 = T.Success })
            TW(VerifyFill, TweenInfo.new(.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2.new(1, 0, 1, 0) })
            TW(StatusFill, TweenInfo.new(.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = T.Success })

        elseif state == "fail" then
            VerifyLabel.Text       = "Try Again"
            VerifyLabel.TextColor3 = T.Title
            HintLabel.Text         = "Key not recognised — please check and retry."
            TW(VerifyBtn,   EI,  { BackgroundColor3 = T.Highlight })
            TW(InputStroke, EI,  { Color = T.Error })
            TW(StatusFill,  EI2, { Size = UDim2.new(0,0,1,0), BackgroundColor3 = T.Error })
            task.delay(.9, function()
                TW(InputStroke, EI, { Color = T.Border })
                TW(StatusFill,  EI, { BackgroundColor3 = T.Highlight })
            end)
        end
    end

    SetStatus("idle")

    -- ── Submit ─────────────────────────────────────────────────────────────
    local function Submit()
        if processing then return end
        local key = InputBox.Text:gsub("%s+", "")
        if key == "" then
            HintLabel.Text = "Please enter your key first."
            TW(InputStroke, TweenInfo.new(.07), { Color = T.Error })
            task.delay(.8, function()
                TW(InputStroke, EI, { Color = T.Border })
                HintLabel.Text = ""
            end)
            return
        end

        processing = true
        SetStatus("loading")
        HintLabel.Text = ""

        local dots, stop = 0, false
        task.spawn(function()
            while not stop do
                dots = (dots % 3) + 1
                if VerifyLabel and VerifyLabel.Parent then
                    VerifyLabel.Text = "Checking" .. string.rep(".", dots)
                end
                task.wait(.33)
            end
        end)

        task.spawn(function()
            local ok = false
            if Junkie and Junkie.check_key then
                local s, r = pcall(function() return Junkie.check_key(key) end)
                if s and r then
                    if type(r) == "boolean" then ok = r
                    elseif type(r) == "table" then
                        ok = r.valid == true or r.message == "KEY_VALID" or r.message == "KEYLESS"
                    end
                end
            else
                task.wait(.7); ok = true
            end

            stop = true; processing = false

            if ok then
                saveKey(key)
                SetStatus("success")
                task.wait(1.4)
                TW(Win, TweenInfo.new(.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    { Position = UDim2.new(.5,0,.5,-40) })
                TW(Win, TweenInfo.new(.35), { BackgroundTransparency = 1 })
                task.wait(.42)
                SG:Destroy()
                task.spawn(onSuccess, key)
            else
                SetStatus("fail")
            end
        end)
    end

    VerifyClick.MouseButton1Up:Connect(Submit)
    UserInputService.InputBegan:Connect(function(inp, proc)
        if proc then return end
        if inp.KeyCode == Enum.KeyCode.Return or inp.KeyCode == Enum.KeyCode.KeypadEnter then
            Submit()
        end
    end)

    -- ── Auto-check saved key ───────────────────────────────────────────────
    task.spawn(function()
        local saved = loadKey()
        if not saved or not (Junkie and Junkie.check_key) then return end
        local s, r = pcall(function() return Junkie.check_key(saved) end)
        local valid = false
        if s and r then
            if type(r) == "boolean" then valid = r
            elseif type(r) == "table" then
                valid = r.valid == true or r.message == "KEY_VALID" or r.message == "KEYLESS"
            end
        end
        if valid then
            InputBox.Text = saved
            processing    = true
            SetStatus("success")
            task.wait(1.4)
            TW(Win, TweenInfo.new(.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                { Position = UDim2.new(.5,0,.5,-40) })
            TW(Win, TweenInfo.new(.35), { BackgroundTransparency = 1 })
            task.wait(.42)
            SG:Destroy()
            task.spawn(onSuccess, saved)
        else
            clearKey()
        end
    end)

    -- ── Close ──────────────────────────────────────────────────────────────
    local function Close()
        TW(Win, TweenInfo.new(.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(.5,0,.5,50) })
        task.wait(.32)
        SG:Destroy()
        task.spawn(onFail)
    end

    CloseBtn.MouseButton1Up:Connect(Close)

    return SG
end

return KeyUI
