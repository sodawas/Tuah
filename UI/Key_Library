    local ContentArea = New("Frame", {
        Parent = Win, AnchorPoint = Vector2.new(1,0),
        Position = UDim2.new(1,0,0,0),
        Size = UDim2.new(0, CONT_W, 1, 0),
        BackgroundTransparency = 1, ZIndex = 11,
