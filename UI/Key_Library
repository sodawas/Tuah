            Parent = pill, Position = UDim2.new(0,26,0,7),
            Size = UDim2.new(1,-30,0,13),
            BackgroundTransparency = 1, Text = pd.head,
            TextColor3 = T.Highlight, FontFace = FONT_BOLD, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 15,
