    local function Close()
        TW(Win, TweenInfo.new(.32, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(.5, 0, .5, 45) });
        task.wait(.34);
        SG:Destroy();
        task.spawn(onFail);
    end;

    CloseBtn.MouseButton1Up:Connect(Close);

    return SG;
end;

return KeyUI;
