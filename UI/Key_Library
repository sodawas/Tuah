    local CARD_COLS = 2
    local CARD_W    = math.floor((CONT_W - 40 - (CARD_COLS-1)*CARD_GAP) / CARD_COLS)

    for i, cd in ipairs(cardDefs) do
        local col2 = (i-1) % CARD_COLS
        local row2 = math.floor((i-1) / CARD_COLS)
        local c = New("Frame", {Parent=InfoPage, Position=UDim2.new(0, col2*(CARD_W+CARD_GAP), 0, 36+row2*(CARD_H+CARD_GAP)), Size=UDim2.new(0,CARD_W,0,CARD_H), BackgroundColor3=T.Tone, ZIndex=13})
        Corner(c,9); Stroke(c,T.Border,1)
        local ib2 = New("Frame", {Parent=c, Position=UDim2.new(0,13,0,13), Size=UDim2.new(0,32,0,32), BackgroundColor3=T.Accent, ZIndex=14})
        Corner(ib2,16)
        New("ImageLabel", {Parent=ib2, AnchorPoint=Vector2.new(.5,.5), Position=UDim2.new(.5,0,.5,0), Size=UDim2.new(0,17,0,17), BackgroundTransparency=1, Image=cd.icon, ImageColor3=cd.col, ZIndex=15})
        New("TextLabel", {Parent=c, Position=UDim2.new(0,54,0,10), Size=UDim2.new(1,-60,0,14), BackgroundTransparency=1, Text=cd.label, TextColor3=T.Subtext, FontFace=FONT_BOLD, TextSize=10, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14})
        New("TextLabel", {Parent=c, Position=UDim2.new(0,54,0,26), Size=UDim2.new(1,-60,0,20), BackgroundTransparency=1, Text=cd.value, TextColor3=T.Title, FontFace=FONT_SB, TextSize=13, TextTruncate=Enum.TextTruncate.AtEnd, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14})
    end
    local TAB_DEFS = {
        {id="verify", img=ICONS.key,  label="Key"},
        {id="games",  img=ICONS.grid, label="Games"},
        {id="info",   img=ICONS.info, label="Info"},
    }
    local pages     = {verify=VerifyPage, games=GamesPage, info=InfoPage}
    local activeTab = "verify"
    local tabBtns, tabIndics = {}, {}

    local function SwitchTab(id)
        if activeTab == id then return end
        activeTab = id
        for tid, pg in pairs(pages) do pg.Visible = (tid==id) end
        for tid, d  in pairs(tabBtns) do
            local on = (tid==id)
            TW(d.bg,  EI, {BackgroundColor3=on and T.Accent or RGB(0,0,0), BackgroundTransparency=on and 0 or 1})
            TW(d.img, EI, {ImageColor3=on and T.Highlight or T.Subtext})
            TW(d.lbl, EI, {TextColor3 =on and T.Highlight or T.Subtext})
            tabIndics[tid].Visible = on
        end
    end

    for _, td in ipairs(TAB_DEFS) do
        local yPos = 90 + (_ - 1) * 66
    end
    for idx2, td in ipairs(TAB_DEFS) do
        local yPos = 90 + (idx2-1)*66
        local isOn = (td.id == activeTab)
        local indic = New("Frame", {Parent=Sidebar, Position=UDim2.new(0,0,0,yPos+11), Size=UDim2.new(0,3,0,28), BackgroundColor3=T.Highlight, ZIndex=14, Visible=isOn})
        Corner(indic,2)
        tabIndics[td.id] = indic
        local bg = New("Frame", {Parent=Sidebar, AnchorPoint=Vector2.new(.5,0), Position=UDim2.new(.5,0,0,yPos), Size=UDim2.new(0,88,0,52), BackgroundColor3=isOn and T.Accent or RGB(0,0,0), BackgroundTransparency=isOn and 0 or 1, ZIndex=13})
        Corner(bg,9)
        local img2 = New("ImageLabel", {Parent=bg, AnchorPoint=Vector2.new(.5,0), Position=UDim2.new(.5,0,0,8), Size=UDim2.new(0,21,0,21), BackgroundTransparency=1, Image=td.img, ImageColor3=isOn and T.Highlight or T.Subtext, ZIndex=14})
        local lbl2 = New("TextLabel", {Parent=bg, AnchorPoint=Vector2.new(.5,1), Position=UDim2.new(.5,0,1,-5), Size=UDim2.new(1,-8,0,12), BackgroundTransparency=1, Text=td.label, TextColor3=isOn and T.Highlight or T.Subtext, FontFace=FONT_BOLD, TextSize=10, ZIndex=14})
        local clk2 = New("TextButton", {Parent=bg, Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", ZIndex=15})
        tabBtns[td.id] = {bg=bg, img=img2, lbl=lbl2}
        clk2.MouseButton1Up:Connect(function() SwitchTab(td.id) end)
        clk2.MouseEnter:Connect(function()
            if activeTab ~= td.id then TW(bg,EI,{BackgroundColor3=T.Tone,BackgroundTransparency=0}); TW(img2,EI,{ImageColor3=T.Text}); TW(lbl2,EI,{TextColor3=T.Text}) end end)
        clk2.MouseLeave:Connect(function()
            if activeTab ~= td.id then TW(bg,EI,{BackgroundTransparency=1}); TW(img2,EI,{ImageColor3=T.Subtext}); TW(lbl2,EI,{TextColor3=T.Subtext}) end end)
    end
    local processing = false

    local function SetStatus(state)
        if state == "idle" then
            VerifyLabel.Text="Verify Key  →"; VerifyLabel.TextColor3=T.Title; HintLabel.Text=""
            TW(VerifyBtn,EI,{BackgroundColor3=T.Highlight})
        elseif state == "loading" then
            TW(VerifyBtn,EI,{BackgroundColor3=T.Hover})
        elseif state == "success" then
            VerifyLabel.Text="Verified  ✓"; VerifyLabel.TextColor3=T.Background; HintLabel.Text=""
            TW(VerifyBtn,EI,{BackgroundColor3=T.Success})
            TW(VerifyFill, TweenInfo.new(.5,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {Size=UDim2.new(1,0,1,0)})
        elseif state == "fail" then
            VerifyLabel.Text="Try Again"; VerifyLabel.TextColor3=T.Title
            HintLabel.Text="Key not recognised — please check and retry."
            TW(VerifyBtn,EI,{BackgroundColor3=T.Highlight})
            TW(InputStroke,EI,{Color=T.Error})
            task.delay(.9, function() TW(InputStroke,EI,{Color=T.Border}) end)
        end
    end
    SetStatus("idle")

    local function AnimateClose(cb)
        TW(Win, TweenInfo.new(.35,Enum.EasingStyle.Quad,Enum.EasingDirection.In), {Position=UDim2.new(.5,0,.5,-35)})
        task.wait(.2)
        TW(Win, TweenInfo.new(.25), {BackgroundTransparency=1})
        task.wait(.27)
        if SG and SG.Parent then SG:Destroy() end
        if cb then task.spawn(cb) end
    end
    local function RawCheck(key)
        if not Junkie or not Junkie.check_key then
            task.wait(.2); return (key ~= nil and key ~= "")
        end
        local s, r = pcall(function() return Junkie.check_key(key) end)
        if not s or r == nil then return false end
        if type(r) == "boolean" then return r end
        if type(r) == "table" then
            return r.valid == true
                or r.message == "KEY_VALID"
                or r.message == "KEYLESS"
        end
        return false
    end
    local function Submit()
        if processing then return end
        local key = InputBox.Text:gsub("%s+","")
        if key == "" then
            HintLabel.Text="Please enter your key first."
            TW(InputStroke,TweenInfo.new(.07),{Color=T.Error})
            task.delay(.8, function() TW(InputStroke,EI,{Color=T.Border}); HintLabel.Text="" end)
            return
        end
        processing = true
        SetStatus("loading"); HintLabel.Text=""
        local dots, stop = 0, false
        task.spawn(function()
            while not stop do
                dots=(dots%3)+1
                if VerifyLabel and VerifyLabel.Parent then
                    VerifyLabel.Text="Checking"..string.rep(".",dots) end
                task.wait(.33)
            end
        end)

        task.spawn(function()
            local ok = RawCheck(key)
            stop = true; processing = false
            if ok then
                saveKey(key)
                SetStatus("success")
                task.wait(1.4)
                AnimateClose(function() onSuccess(key) end)
            else
                SetStatus("fail")
            end
        end)
    end
    VerifyClick.MouseButton1Up:Connect(Submit)
    UserInputService.InputBegan:Connect(function(inp, proc)
        if proc then return end
        if inp.KeyCode==Enum.KeyCode.Return or inp.KeyCode==Enum.KeyCode.KeypadEnter then Submit() end
    end)
    task.spawn(function()
        task.wait()
        local saved = loadKey()
        if not saved then return end

        HintLabel.TextColor3 = T.Subtext
        HintLabel.Text = "Checking saved key…"

        local valid = RawCheck(saved)
        if not (SG and SG.Parent) then return end

        if valid then
            InputBox.Text = saved
            SetStatus("success")
            task.wait(1.4)
            AnimateClose(function() onSuccess(saved) end)
        else
            HintLabel.Text = ""
            clearKey()
        end
    end)
    CloseBtn.MouseButton1Up:Connect(function() AnimateClose(onFail) end)

    return SG
end

return KeyUI
