    local WIN_W  = 640
    local WIN_H  = 430
    local SIDE_W = 110

    local Win = New("Frame", {
        Parent = SG, AnchorPoint = Vector2.new(.5,.5),
        Position = UDim2.new(.5,0,.5,30),
        Size     = UDim2.new(0, WIN_W, 0, WIN_H),
