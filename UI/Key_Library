        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 14,
    })
    New("TextLabel", {
        Parent = CI, Position = UDim2.new(0,0,0,224),
        Size = UDim2.new(1,0,0,13),
        BackgroundTransparency = 1,
