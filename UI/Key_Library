    })
    VerifyClick.MouseEnter:Connect(function()  TW(VerifyBtn, EI, { BackgroundColor3 = T.Selected }) end)
    VerifyClick.MouseLeave:Connect(function()  TW(VerifyBtn, EI, { BackgroundColor3 = T.Highlight }) end)
    VerifyClick.MouseButton1Down:Connect(function() TW(VerifyBtn, EI, { BackgroundColor3 = T.Hover }) end)

    -- ── Copy key link ──────────────────────────────────────────────────────
    local CopyBtn = New("Frame", {
        Parent = CI, Position = UDim2.new(0,0,0,155),
        Size = UDim2.new(1,0,0,32),
        BackgroundColor3 = T.Background, ZIndex = 14,
    })
    Corner(CopyBtn, 6)
    local CopyStroke = Stroke(CopyBtn, T.Border, 1)

    local CopyLabel = New("TextLabel", {
        Parent = CopyBtn, Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, Text = "Copy key link",
        TextColor3 = T.Text, FontFace = FONT_SB, TextSize = 12, ZIndex = 15,
    })
    local CopyClick = New("TextButton", {
        Parent = CopyBtn, Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, Text = "", ZIndex = 16,
    })
    CopyClick.MouseEnter:Connect(function()
        TW(CopyBtn, EI, { BackgroundColor3 = T.Tone })
        TW(CopyStroke, EI, { Color = T.Hover })
    end)
    CopyClick.MouseLeave:Connect(function()
        TW(CopyBtn, EI, { BackgroundColor3 = T.Background })
        TW(CopyStroke, EI, { Color = T.Border })
    end)
    CopyClick.MouseButton1Up:Connect(function()
        local link = keyLink
        if Junkie and Junkie.get_key_link then
            local ok, r = pcall(function() return Junkie.get_key_link() end)
            if ok and r then link = r end
        end
        pcall(function() setclipboard(link) end)
        local orig = CopyLabel.Text
        CopyLabel.Text = "Copied!"; CopyLabel.TextColor3 = T.Highlight
        task.delay(1.5, function()
            if CopyLabel and CopyLabel.Parent then
                CopyLabel.Text = orig; CopyLabel.TextColor3 = T.Text
            end
        end)
    end)

