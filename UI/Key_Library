    -- ── State machine ─────────────────────────────────────────────────────
    local processing = false;

    local function SetState(state)
        RowLocked.Visible = false;
        RowOK.Visible     = false;
        RowFail.Visible   = false;

        if state == "idle" then
            RowLocked.Visible  = true;
            AuthLabel.Text     = "Authenticate  →";
            HintLabel.Text     = "";
            AuthLabel.TextColor3 = T.Text;

        elseif state == "loading" then
            RowLocked.Visible  = true;

        elseif state == "success" then
            RowOK.Visible      = true;
            AuthLabel.Text     = "Verified  ✓";
            TW(AuthStroke, EI, { Color = T.Success });
            TW(AuthFill, TweenInfo.new(.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2.new(1, 0, 1, 0) });
            task.delay(.05, function()
                TW(AuthLabel, EI2, { TextColor3 = T.Background });
            end);

        elseif state == "fail" then
            RowFail.Visible    = true;
            AuthLabel.Text     = "Try Again";
            HintLabel.Text     = "Key not recognised — please check and retry.";
            TW(InputStroke, EI, { Color = T.Error });
            task.delay(.9, function()
                TW(InputStroke, EI, { Color = T.Accent1 });
            end);
        end;
    end;

    SetState("idle");

    -- ── Submit logic ──────────────────────────────────────────────────────
    local function Submit()
        if processing then return; end;
        local key = InputBox.Text;

        if key == "" then
            HintLabel.Text = "Enter a key first.";
            TW(InputStroke, TweenInfo.new(.07), { Color = T.Error });
            task.delay(.7, function()
                TW(InputStroke, EI, { Color = T.Accent1 });
                HintLabel.Text = "";
            end);
            return;
        end;

        processing = true;
        SetState("loading");
        HintLabel.Text = "";

        local dots, stop = 0, false;
        task.spawn(function()
            while not stop do
                dots = (dots % 3) + 1;
                if AuthLabel and AuthLabel.Parent then
                    AuthLabel.Text = "Checking" .. string.rep(".", dots);
                end;
                task.wait(.33);
            end;
        end);

        task.spawn(function()
            local ok;
            if validate then
                local s, r = pcall(validate, key);
                ok = s and r;
            else
                task.wait(.7);
                ok = (key ~= "");
            end;

            stop = true;
            processing = false;

            if ok then
                SetState("success");
                task.wait(1.3);
                -- exit animation
                TW(Win, TweenInfo.new(.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    { Position = UDim2.new(.5, 0, .5, -35) });
                TW(Win, TweenInfo.new(.35), { BackgroundTransparency = 1 });
                task.wait(.42);
                SG:Destroy();
                task.spawn(onSuccess, key);
            else
                SetState("fail");
            end;
        end);
    end;

    AuthClick.MouseButton1Up:Connect(Submit);

