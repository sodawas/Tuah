    if #freeGames == 0 then
        New("TextLabel", {
            Parent = FreeList, Size = UDim2.new(1,0,0,28),
            BackgroundTransparency = 1, Text = "None listed",
            TextColor3 = T.Subtext, FontFace = FONT, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 15,
        })
    end

    -- ════════════════════════════════════════════════════════════════
    -- PAGE 3 — INFO
    -- ════════════════════════════════════════════════════════════════
    local InfoPage = MakePage()
    Pad(InfoPage, 22, 22, 18, 18)

    New("TextLabel", {
        Parent = InfoPage, Size = UDim2.new(1,0,0,20),
        BackgroundTransparency = 1,
        Text = appTitle .. "  ·  Information",
        TextColor3 = T.Title, FontFace = FONT_BOLD, TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13,
    })

    local infoRows = {
        { "Version",      "v7.0" },
        { "Key Provider", "Junkie  (jnkie.com)" },
        { "Key Format",   "buried-XXXX-XXXX-XXXX-XXX" },
        { "Key Storage",  fsOk and "Auto-saved locally" or "Session only (no filesystem)" },
        { "Support",      "discord.gg/lotus" },
    }

    for i, row in ipairs(infoRows) do
        local yB = 30 + (i-1) * 28
        New("TextLabel", {
            Parent = InfoPage, Position = UDim2.new(0,0,0,yB),
            Size = UDim2.new(.4,0,0,17),
            BackgroundTransparency = 1, Text = row[1],
            TextColor3 = T.Subtext, FontFace = FONT_BOLD, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13,
        })
        New("TextLabel", {
            Parent = InfoPage, Position = UDim2.new(.4,0,0,yB),
            Size = UDim2.new(.6,0,0,17),
            BackgroundTransparency = 1, Text = row[2],
            TextColor3 = T.Text, FontFace = FONT, TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13,
        })
        New("Frame", {
            Parent = InfoPage, Position = UDim2.new(0,0,0,yB+19),
            Size = UDim2.new(1,0,0,1),
            BackgroundColor3 = T.Border, ZIndex = 13,
        })
    end

    -- ════════════════════════════════════════════════════════════════
    -- SIDEBAR TAB BUTTONS
    -- ════════════════════════════════════════════════════════════════
    local TAB_DEFS = {
        { id = "verify", img = ICONS.key,     label = "Key" },
        { id = "games",  img = ICONS.gamepad, label = "Games" },
        { id = "info",   img = ICONS.info,    label = "Info" },
    }

    local pages     = { verify = VerifyPage, games = GamesPage, info = InfoPage }
    local activeTab = "verify"
    local tabBtns   = {}
    local tabIndics = {}

    local BTN_Y0 = 80
    local BTN_SP = 60

    local function SwitchTab(id)
        if activeTab == id then return end
        activeTab = id
        for tid, pg in pairs(pages) do pg.Visible = (tid == id) end
        for tid, d in pairs(tabBtns) do
            local on = (tid == id)
            TW(d.bg,  EI, { BackgroundColor3 = on and T.Accent or RGB(0,0,0),
                             BackgroundTransparency = on and 0 or 1 })
            TW(d.img, EI, { ImageColor3 = on and T.Highlight or T.Subtext })
            TW(d.lbl, EI, { TextColor3  = on and T.Highlight or T.Subtext })
            tabIndics[tid].Visible = on
        end
    end

    for idx, td in ipairs(TAB_DEFS) do
        local yPos = BTN_Y0 + (idx-1)*BTN_SP
        local isOn = (td.id == activeTab)

        local indic = New("Frame", {
            Parent = Sidebar, Position = UDim2.new(0,0,0,yPos+9),
            Size = UDim2.new(0,2,0,26),
            BackgroundColor3 = T.Highlight, ZIndex = 14, Visible = isOn,
        })
        Corner(indic, 2)
        tabIndics[td.id] = indic

        local bg = New("Frame", {
            Parent = Sidebar, AnchorPoint = Vector2.new(.5,0),
            Position = UDim2.new(.5,0,0,yPos),
            Size = UDim2.new(0,80,0,46),
            BackgroundColor3     = isOn and T.Accent or RGB(0,0,0),
            BackgroundTransparency = isOn and 0 or 1,
            ZIndex = 13,
        })
        Corner(bg, 8)

        local img = New("ImageLabel", {
            Parent = bg, AnchorPoint = Vector2.new(.5,0),
            Position = UDim2.new(.5,0,0,7), Size = UDim2.new(0,17,0,17),
            BackgroundTransparency = 1,
            Image = td.img, ImageColor3 = isOn and T.Highlight or T.Subtext,
            ZIndex = 14,
        })

        local lbl = New("TextLabel", {
            Parent = bg, AnchorPoint = Vector2.new(.5,1),
            Position = UDim2.new(.5,0,1,-5),
            Size = UDim2.new(1,-8,0,10),
            BackgroundTransparency = 1, Text = td.label,
            TextColor3 = isOn and T.Highlight or T.Subtext,
            FontFace = FONT_BOLD, TextSize = 8, ZIndex = 14,
        })

        local clk = New("TextButton", {
            Parent = bg, Size = UDim2.new(1,0,1,0),
            BackgroundTransparency = 1, Text = "", ZIndex = 15,
        })

        tabBtns[td.id] = { bg = bg, img = img, lbl = lbl }

        clk.MouseButton1Up:Connect(function() SwitchTab(td.id) end)
        clk.MouseEnter:Connect(function()
            if activeTab ~= td.id then
                TW(bg,  EI, { BackgroundColor3 = T.Tone, BackgroundTransparency = 0 })
                TW(img, EI, { ImageColor3 = T.Text })
                TW(lbl, EI, { TextColor3  = T.Text })
            end
        end)
        clk.MouseLeave:Connect(function()
            if activeTab ~= td.id then
                TW(bg,  EI, { BackgroundTransparency = 1 })
                TW(img, EI, { ImageColor3 = T.Subtext })
                TW(lbl, EI, { TextColor3  = T.Subtext })
            end
        end)
    end

    -- ════════════════════════════════════════════════════════════════
    -- STATE MACHINE
    -- ════════════════════════════════════════════════════════════════
    local processing = false

    local function SetStatus(state)
        if state == "idle" then
            VerifyLabel.Text = "Verify Key  →"; VerifyLabel.TextColor3 = T.Title
            HintLabel.Text   = ""
            TW(VerifyBtn,  EI,  { BackgroundColor3 = T.Highlight })
            TW(StatusFill, EI2, { Size = UDim2.new(0,0,1,0), BackgroundColor3 = T.Highlight })

        elseif state == "loading" then
            TW(VerifyBtn, EI, { BackgroundColor3 = T.Hover })

        elseif state == "success" then
            VerifyLabel.Text = "Verified  ✓"; VerifyLabel.TextColor3 = T.Background
            HintLabel.Text   = ""
            TW(VerifyBtn,  EI,  { BackgroundColor3 = T.Success })
            TW(VerifyFill, TweenInfo.new(.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { Size = UDim2.new(1,0,1,0) })
            TW(StatusFill, EI3, { Size = UDim2.new(1,0,1,0), BackgroundColor3 = T.Success })

        elseif state == "fail" then
            VerifyLabel.Text = "Try Again"; VerifyLabel.TextColor3 = T.Title
            HintLabel.Text   = "Key not recognised — please check and retry."
            TW(VerifyBtn,   EI,  { BackgroundColor3 = T.Highlight })
            TW(InputStroke, EI,  { Color = T.Error })
            TW(StatusFill,  EI2, { Size = UDim2.new(0,0,1,0), BackgroundColor3 = T.Error })
            task.delay(.9, function()
                TW(InputStroke, EI, { Color = T.Border })
                TW(StatusFill,  EI, { BackgroundColor3 = T.Highlight })
            end)
        end
    end

    SetStatus("idle")

    -- ════════════════════════════════════════════════════════════════
    -- SUBMIT
    -- ════════════════════════════════════════════════════════════════
    local function Submit()
        if processing then return end
        local key = InputBox.Text:gsub("%s+", "")
        if key == "" then
            HintLabel.Text = "Please enter your key first."
            TW(InputStroke, TweenInfo.new(.07), { Color = T.Error })
            task.delay(.8, function()
                TW(InputStroke, EI, { Color = T.Border })
                HintLabel.Text = ""
            end)
            return
        end

        processing = true; SetStatus("loading"); HintLabel.Text = ""

        local dots, stop = 0, false
        task.spawn(function()
            while not stop do
                dots = (dots % 3) + 1
                if VerifyLabel and VerifyLabel.Parent then
                    VerifyLabel.Text = "Checking" .. string.rep(".", dots)
                end
                task.wait(.33)
            end
        end)

        task.spawn(function()
            local ok = false
            if Junkie and Junkie.check_key then
                local s, r = pcall(function() return Junkie.check_key(key) end)
                if s and r then
                    if type(r) == "boolean" then ok = r
                    elseif type(r) == "table" then
                        ok = r.valid == true or r.message == "KEY_VALID" or r.message == "KEYLESS"
                    end
                end
            else
                task.wait(.7); ok = true
            end

            stop = true; processing = false

            if ok then
                saveKey(key); SetStatus("success")
                task.wait(1.4)
                TW(Win, TweenInfo.new(.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    { Position = UDim2.new(.5,0,.5,-40) })
                TW(Win, TweenInfo.new(.35), { BackgroundTransparency = 1 })
                task.wait(.42); SG:Destroy(); task.spawn(onSuccess, key)
            else
                SetStatus("fail")
            end
        end)
    end

    VerifyClick.MouseButton1Up:Connect(Submit)
    UserInputService.InputBegan:Connect(function(inp, proc)
        if proc then return end
        if inp.KeyCode == Enum.KeyCode.Return or inp.KeyCode == Enum.KeyCode.KeypadEnter then
            Submit()
        end
    end)

    -- ── Auto-check saved key ───────────────────────────────────────────────
    task.spawn(function()
        local saved = loadKey()
        if not saved or not (Junkie and Junkie.check_key) then return end
        local s, r = pcall(function() return Junkie.check_key(saved) end)
        local valid = false
        if s and r then
            if type(r) == "boolean" then valid = r
            elseif type(r) == "table" then
                valid = r.valid == true or r.message == "KEY_VALID" or r.message == "KEYLESS"
            end
        end
        if valid then
            InputBox.Text = saved; processing = true; SetStatus("success")
            task.wait(1.4)
            TW(Win, TweenInfo.new(.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                { Position = UDim2.new(.5,0,.5,-40) })
            TW(Win, TweenInfo.new(.35), { BackgroundTransparency = 1 })
            task.wait(.42); SG:Destroy(); task.spawn(onSuccess, saved)
        else
            clearKey()
        end
    end)

    -- ── Close ──────────────────────────────────────────────────────────────
    local function Close()
        TW(Win, TweenInfo.new(.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(.5,0,.5,50) })
        task.wait(.32); SG:Destroy(); task.spawn(onFail)
    end
    CloseBtn.MouseButton1Up:Connect(Close)

    return SG
end

return KeyUI
