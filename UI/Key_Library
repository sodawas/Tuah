-- ── Helpers ────────────────────────────────────────────────────────────────
local function New(class, props)
    local i = Instance.new(class)
    for k, v in next, props do i[k] = v end
    pcall(function() i.BorderSizePixel = 0 end)
    return i
end

local function Corner(p, r)   New("UICorner",  { Parent = p, CornerRadius = UDim.new(0, r or 6) }) end
local function Divider(p, r)  New("UIStroke",  { Parent = p, Color = T.Border, Thickness = 1,
                                                  LineJoinMode = Enum.LineJoinMode.Round,
                                                  ApplyStrokeMode = Enum.ApplyStrokeMode.Border }) end
local function TW(i, ti, pr) TweenService:Create(i, ti, pr):Play() end

local EI  = TweenInfo.new(.15, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
local EI2 = TweenInfo.new(.30, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

-- ── File helpers ───────────────────────────────────────────────────────────
local function hasFS()
    return pcall(function() return type(writefile) == "function" end)
        and pcall(function() return type(readfile)  == "function" end)
end
local fsOk = hasFS()

local function saveKey(k)   if not fsOk then return end; pcall(function() writefile("_junkie_key.txt", k) end) end
local function loadKey()    if not fsOk then return nil end; local ok, v = pcall(function() return readfile("_junkie_key.txt") end); return (ok and v and v ~= "") and v or nil end
local function clearKey()   if not fsOk then return end; pcall(function() delfile("_junkie_key.txt") end) end

