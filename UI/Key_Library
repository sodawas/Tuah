            Position=UDim2.new(1,-12,.5,0),
            Size=UDim2.new(0, entry.free and 44 or 90, 0,20),
            BackgroundColor3=T.Accent, ZIndex=15 })
        Corner(tag, 10)
        New("UIStroke", { Parent=tag, Color=tagColor, Thickness=1,
            Transparency=.55, ApplyStrokeMode=Enum.ApplyStrokeMode.Border })
        New("TextLabel", { Parent=tag, Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, Text=tagText,
            TextColor3=tagColor, FontFace=FONT_BOLD, TextSize=10, ZIndex=16 })

        -- hover
        local click = New("TextButton", { Parent=row, Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, Text="", ZIndex=17 })
        click.MouseEnter:Connect(function() TW(row,EI,{BackgroundColor3=T.Accent}) end)
        click.MouseLeave:Connect(function() TW(row,EI,{BackgroundColor3=T.Tone}) end)
    end

    -- ════════════════════════════════════════════════════════════════
    -- PAGE 3 — INFO  (live stats + useful info)
    -- ════════════════════════════════════════════════════════════════
    local InfoPage = MakePage()
    Pad(InfoPage, 20,20,18,18)

    -- Section title
    New("TextLabel", { Parent=InfoPage, Size=UDim2.new(1,0,0,20),
        BackgroundTransparency=1,
        Text=appTitle .. "  ·  Overview",
        TextColor3=T.Title, FontFace=FONT_BOLD, TextSize=14,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=13 })

    New("Frame", { Parent=InfoPage, Position=UDim2.new(0,0,0,26),
        Size=UDim2.new(1,0,0,1), BackgroundColor3=T.Border, ZIndex=13 })

    -- Info card grid: 2 columns of cards
    local cardDefs = {
        { icon=ICONS.version,  label="Version",    value=appVer,                   col=T.Highlight },
        { icon=ICONS.game,     label="Game",        value=getGame(),                col=T.Highlight },
        { icon=ICONS.executor, label="Executor",    value=getExecutor(),            col=T.Highlight },
        { icon=ICONS.clock,    label="Launched",    value=getTime(),                col=T.Highlight },
        { icon=ICONS.support,  label="Support",     value=appSupp,                  col=T.Highlight },
        { icon=ICONS.tag,      label="Key Storage", value=fsOk and "Auto-saved" or "Session only", col=T.Highlight },
    }

    local CARD_H    = 58
    local CARD_GAP  = 8
    local CARD_COLS = 2
    local CARD_W    = math.floor((CONT_W - 40 - (CARD_COLS-1)*CARD_GAP) / CARD_COLS)

    for i, cd in ipairs(cardDefs) do
        local col = (i-1) % CARD_COLS
        local row = math.floor((i-1) / CARD_COLS)
        local xOff = col * (CARD_W + CARD_GAP)
        local yOff = 34 + row * (CARD_H + CARD_GAP)

        local c = New("Frame", { Parent=InfoPage,
            Position=UDim2.new(0,xOff,0,yOff),
            Size=UDim2.new(0,CARD_W,0,CARD_H),
            BackgroundColor3=T.Tone, ZIndex=13 })
        Corner(c, 7)
        Stroke(c, T.Border, 1)

        -- icon circle bg
        local iconBg = New("Frame", { Parent=c,
            Position=UDim2.new(0,12,0,12),
            Size=UDim2.new(0,32,0,32),
            BackgroundColor3=T.Accent, ZIndex=14 })
        Corner(iconBg, 16)
        New("ImageLabel", { Parent=iconBg, AnchorPoint=Vector2.new(.5,.5),
            Position=UDim2.new(.5,0,.5,0), Size=UDim2.new(0,16,0,16),
            BackgroundTransparency=1, Image=cd.icon, ImageColor3=cd.col, ZIndex=15 })

        -- label + value
        New("TextLabel", { Parent=c,
            Position=UDim2.new(0,52,0,10),
            Size=UDim2.new(1,-58,0,14),
            BackgroundTransparency=1, Text=cd.label,
            TextColor3=T.Subtext, FontFace=FONT_BOLD, TextSize=9,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14 })
        New("TextLabel", { Parent=c,
            Position=UDim2.new(0,52,0,26),
            Size=UDim2.new(1,-58,0,18),
            BackgroundTransparency=1, Text=cd.value,
            TextColor3=T.Title, FontFace=FONT_SB, TextSize=12,
            TextXAlignment=Enum.TextXAlignment.Left,
            TextTruncate=Enum.TextTruncate.AtEnd, ZIndex=14 })
    end

    -- ════════════════════════════════════════════════════════════════
    -- SIDEBAR TAB BUTTONS
    -- ════════════════════════════════════════════════════════════════
    local TAB_DEFS = {
        { id="verify", img=ICONS.key,  label="Key" },
        { id="games",  img=ICONS.grid, label="Games" },
        { id="info",   img=ICONS.info, label="Info" },
    }

    local pages     = { verify=VerifyPage, games=GamesPage, info=InfoPage }
    local activeTab = "verify"
    local tabBtns   = {}
    local tabIndics = {}
    local BTN_Y0    = 90
    local BTN_SP    = 66

    local function SwitchTab(id)
        if activeTab == id then return end
        activeTab = id
        for tid, pg in pairs(pages) do pg.Visible = (tid == id) end
        for tid, d in pairs(tabBtns) do
            local on = (tid == id)
            TW(d.bg,  EI, { BackgroundColor3=on and T.Accent or RGB(0,0,0),
                             BackgroundTransparency=on and 0 or 1 })
            TW(d.img, EI, { ImageColor3=on and T.Highlight or T.Subtext })
            TW(d.lbl, EI, { TextColor3 =on and T.Highlight or T.Subtext })
            tabIndics[tid].Visible = on
        end
    end

    for idx, td in ipairs(TAB_DEFS) do
        local yPos = BTN_Y0 + (idx-1)*BTN_SP
        local isOn = (td.id == activeTab)

        local indic = New("Frame", { Parent=Sidebar,
            Position=UDim2.new(0,0,0,yPos+10), Size=UDim2.new(0,2,0,28),
            BackgroundColor3=T.Highlight, ZIndex=14, Visible=isOn })
        Corner(indic, 2)
        tabIndics[td.id] = indic

        local bg = New("Frame", { Parent=Sidebar, AnchorPoint=Vector2.new(.5,0),
            Position=UDim2.new(.5,0,0,yPos), Size=UDim2.new(0,88,0,50),
            BackgroundColor3=isOn and T.Accent or RGB(0,0,0),
            BackgroundTransparency=isOn and 0 or 1, ZIndex=13 })
        Corner(bg, 8)

        local img = New("ImageLabel", { Parent=bg, AnchorPoint=Vector2.new(.5,0),
            Position=UDim2.new(.5,0,0,7), Size=UDim2.new(0,19,0,19),
            BackgroundTransparency=1, Image=td.img,
            ImageColor3=isOn and T.Highlight or T.Subtext, ZIndex=14 })

        local lbl = New("TextLabel", { Parent=bg, AnchorPoint=Vector2.new(.5,1),
            Position=UDim2.new(.5,0,1,-5), Size=UDim2.new(1,-8,0,11),
            BackgroundTransparency=1, Text=td.label,
            TextColor3=isOn and T.Highlight or T.Subtext,
            FontFace=FONT_BOLD, TextSize=9, ZIndex=14 })

        local clk = New("TextButton", { Parent=bg, Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, Text="", ZIndex=15 })

        tabBtns[td.id] = { bg=bg, img=img, lbl=lbl }
        clk.MouseButton1Up:Connect(function() SwitchTab(td.id) end)
        clk.MouseEnter:Connect(function()
            if activeTab ~= td.id then
                TW(bg, EI,{BackgroundColor3=T.Tone,BackgroundTransparency=0})
                TW(img,EI,{ImageColor3=T.Text}); TW(lbl,EI,{TextColor3=T.Text}) end end)
        clk.MouseLeave:Connect(function()
            if activeTab ~= td.id then
                TW(bg, EI,{BackgroundTransparency=1})
                TW(img,EI,{ImageColor3=T.Subtext}); TW(lbl,EI,{TextColor3=T.Subtext}) end end)
    end

    -- ════════════════════════════════════════════════════════════════
    -- STATE MACHINE
    -- ════════════════════════════════════════════════════════════════
    local processing = false

    local function SetStatus(state)
        if state == "idle" then
            VerifyLabel.Text="Verify Key  →"; VerifyLabel.TextColor3=T.Title; HintLabel.Text=""
            TW(VerifyBtn,EI,{BackgroundColor3=T.Highlight})
        elseif state == "loading" then
            TW(VerifyBtn,EI,{BackgroundColor3=T.Hover})
        elseif state == "success" then
            VerifyLabel.Text="Verified  ✓"; VerifyLabel.TextColor3=T.Background; HintLabel.Text=""
            TW(VerifyBtn,EI,{BackgroundColor3=T.Success})
            TW(VerifyFill,TweenInfo.new(.5,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,1,0)})
        elseif state == "fail" then
            VerifyLabel.Text="Try Again"; VerifyLabel.TextColor3=T.Title
            HintLabel.Text="Key not recognised — please check and retry."
            TW(VerifyBtn,EI,{BackgroundColor3=T.Highlight})
            TW(InputStroke,EI,{Color=T.Error})
            task.delay(.9,function() TW(InputStroke,EI,{Color=T.Border}) end)
        end
    end
    SetStatus("idle")

    -- ════════════════════════════════════════════════════════════════
    -- SUBMIT
    -- ════════════════════════════════════════════════════════════════
    local function Submit()
        if processing then return end
        local key = InputBox.Text:gsub("%s+","")
        if key == "" then
            HintLabel.Text="Please enter your key first."
            TW(InputStroke,TweenInfo.new(.07),{Color=T.Error})
            task.delay(.8,function() TW(InputStroke,EI,{Color=T.Border}); HintLabel.Text="" end)
            return
        end
        processing=true; SetStatus("loading"); HintLabel.Text=""

        local dots,stop = 0,false
        task.spawn(function()
            while not stop do
                dots=(dots%3)+1
                if VerifyLabel and VerifyLabel.Parent then
                    VerifyLabel.Text="Checking"..string.rep(".",dots) end
                task.wait(.33) end end)

        task.spawn(function()
            local ok=false
            if Junkie and Junkie.check_key then
                local s,r=pcall(function() return Junkie.check_key(key) end)
                if s and r then
                    if type(r)=="boolean" then ok=r
                    elseif type(r)=="table" then
                        ok=r.valid==true or r.message=="KEY_VALID" or r.message=="KEYLESS" end end
            else task.wait(.7); ok=true end

            stop=true; processing=false
            if ok then
                saveKey(key); SetStatus("success")
                task.wait(1.4)
                TW(Win,TweenInfo.new(.4,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Position=UDim2.new(.5,0,.5,-40)})
                TW(Win,TweenInfo.new(.35),{BackgroundTransparency=1})
                task.wait(.42); SG:Destroy(); task.spawn(onSuccess,key)
            else SetStatus("fail") end
        end)
    end

    VerifyClick.MouseButton1Up:Connect(Submit)
    UserInputService.InputBegan:Connect(function(inp,proc)
        if proc then return end
        if inp.KeyCode==Enum.KeyCode.Return or inp.KeyCode==Enum.KeyCode.KeypadEnter then Submit() end end)

    task.spawn(function()
        local saved=loadKey()
        if not saved or not (Junkie and Junkie.check_key) then return end
        local s,r=pcall(function() return Junkie.check_key(saved) end)
        local valid=false
        if s and r then
            if type(r)=="boolean" then valid=r
            elseif type(r)=="table" then valid=r.valid==true or r.message=="KEY_VALID" or r.message=="KEYLESS" end end
        if valid then
            InputBox.Text=saved; processing=true; SetStatus("success")
            task.wait(1.4)
            TW(Win,TweenInfo.new(.4,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Position=UDim2.new(.5,0,.5,-40)})
            TW(Win,TweenInfo.new(.35),{BackgroundTransparency=1})
            task.wait(.42); SG:Destroy(); task.spawn(onSuccess,saved)
        else clearKey() end
    end)

    local function Close()
        TW(Win,TweenInfo.new(.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In),{Position=UDim2.new(.5,0,.5,50)})
        task.wait(.32); SG:Destroy(); task.spawn(onFail)
    end
    CloseBtn.MouseButton1Up:Connect(Close)
    return SG
end

return KeyUI
