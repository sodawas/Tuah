    })
    Corner(Win, 10)
    Stroke(Win, T.Border, 1)

    TW(Win, TweenInfo.new(.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        { Position = UDim2.new(.5,0,.5,0) })

    -- ── Sidebar ────────────────────────────────────────────────────────────
    local Sidebar = New("Frame", {
        Parent = Win, Size = UDim2.new(0, SIDE_W, 1, 0),
        BackgroundColor3 = T.Sidebar, ZIndex = 11,
    })

    New("Frame", {   -- right border
        Parent = Win, Position = UDim2.new(0, SIDE_W, 0, 0),
        Size = UDim2.new(0, 1, 1, 0),
        BackgroundColor3 = T.Border, ZIndex = 12,
    })

    -- Lotus logo — white
    New("ImageLabel", {
        Parent = Sidebar, AnchorPoint = Vector2.new(.5,0),
        Position = UDim2.new(.5,0,0,15),
        Size     = UDim2.new(0,40,0,40),
