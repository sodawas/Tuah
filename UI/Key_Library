        ResetOnSpawn   = false,
        IgnoreGuiInset = true,
    })

    New("Frame", {
        Parent = SG, Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = RGB(0,0,0), BackgroundTransparency = .52, ZIndex = 1,
    })

    -- ── Window ─────────────────────────────────────────────────────────────
