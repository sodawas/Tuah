function SLIME:auto_slime_gun(s_c)
    s_c = s_c or false;
    local slimegun__event = networker_0_3_1.SlimeGunService.RemoteFunction;

    if not slimegun__event then
        self:client_kick("something unexpected happened with networker path;");
        return;
    end;

    task.spawn(function()
        local ok, err = pcall(function()
            while (getgenv().auto_slime_gun) and (s_c) and slimegun__event do

                if not character:FindFirstChild("SlimeGun") then
                    local gun = client.Backpack:FindFirstChild("SlimeGun");
                    local humanoid = character:FindFirstChildOfClass("Humanoid");
                    if gun and humanoid then
                        humanoid:EquipTool(gun);
                        task.wait(0.2);
                    end;
                    task.wait(0.3);
                    continue;
                end;

                local upgrades = require(replicatedstorage.Packages.DataService).client:get("upgrades") or {};

                if not require(replicatedstorage.Source.Features.Upgrades.UpgradeServiceUtils).ownsUpgrade("slimeGun", upgrades) then
                    task.wait(1);
                    continue;
                end;

                local gun_range = goop_gun_utils.getRange(upgrades);
                local gameplay = gameplay_client.gameplay;

                if gameplay and gameplay.enemies then
                    local nearest_id = nil;
                    local nearest_dist = math.huge;

                    for unique_id, enemy_data in gameplay.enemies do
                        local enemy_root = enemy_data.model and enemy_data.model:FindFirstChild("RootPart");
                        if enemy_root then
                            local dist = (enemy_root.Position - humanoidrootpart.Position).Magnitude;
                            if dist < nearest_dist and dist <= gun_range then
                                nearest_id = unique_id;
                                nearest_dist = dist;
                            end;
                        end;
                    end;

                    if nearest_id then
                        local equipped_gun = character:FindFirstChild("SlimeGun");
                        if equipped_gun then
                            firesignal(equipped_gun.Activated);
                            task.wait(0.05);
                            pcall(function()
                                slimegun__event:InvokeServer("tryFireSlimeGun", nearest_id);
                            end);
                        end;
                    end;
                end;

                local fire_rate = goop_gun_utils.getFireRate(upgrades);
                local wait_time = (type(fire_rate) == "number" and fire_rate > 0) and (1 / fire_rate) or 0.3;
                task.wait(wait_time);
            end;
        end);

        if not ok then
            print("auto_slime_gun error:", err);
        end;
    end);
end;

function SLIME:auto_redeem_codes()
    local ok, response = pcall(function()
        return request({
            Url = "https://beebom.com/slime-rng-codes/",
            Method = "GET"
        });
    end);

    if not ok or not response or response.StatusCode ~= 200 then
        Library:Notify("Failed to fetch codes", 5, "Error");
        return;
    end;

    local blacklist = { "Shop", "Redeem", "NEW", "Home", "Gaming", "Share", "Update" };
    local codes = {};

    for code in response.Body:gmatch("<strong>(.-)</strong>") do
        if not code:find("<") and not code:find(">") then
            local blacklisted = false;
            for _, v in ipairs(blacklist) do
                if code == v then
                    blacklisted = true;
                    break;
                end;
            end;
            if not blacklisted then
                table.insert(codes, code);
            end;
        end;
    end;

    if #codes == 0 then
        Library:Notify("Failed to fetch codes", 5, "Error");
        return;
    end;

    local codeservice__event = replicatedstorage.Packages._Index["leifstout_networker@0.3.1"].networker._remotes.CodeService.RemoteFunction;
    local code_utils = require(replicatedstorage.Source.Features.Codes.CodeServiceUtils);

    if not codeservice__event then
        Library:Notify("CodeService not found", 5, "Error");
        return;
    end;

    local redeemed = 0;
    local already_used = 0;
    local expired = 0;
    local failed = 0;

    for _, code in ipairs(codes) do
        local c_ok, result = pcall(function()
            return codeservice__event:InvokeServer("redeem", code);
        end);

        if c_ok then
            if result == code_utils.REDEEM_ENUMS.success then
                redeemed += 1;
            elseif result == code_utils.REDEEM_ENUMS.alreadyRedeemed then
                already_used += 1;
            elseif result == code_utils.REDEEM_ENUMS.expired then
                expired += 1;
            elseif result == code_utils.REDEEM_ENUMS.invalid then
                --[[ skip ]]--
            else
                failed += 1;
            end;
        else
            failed += 1;
        end;

        task.wait(0.5);
    end;

    Library:Notify(
        "✅ Redeemed: " .. redeemed ..
        "\n🔄 Already Used: " .. already_used ..
        "\n⌛ Expired: " .. expired ..
        "\n❌ Failed: " .. failed,
        10, "Notification"
    );
end;

