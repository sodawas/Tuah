function SLIME:auto_upgrade(u_c)
    u_c = u_c or false;
    local upgradeservice__event = networker_0_3_1.UpgradeService.RemoteFunction;

    if not upgradeservice__event then
        self:client_kick("something unexpected happened with networker path;");
        return;
    end;

    task.spawn(function()
        local ok, err = pcall(function()
            local upgrade_tree = require(replicatedstorage.Source.Features.Upgrades.UpgradeTree);
            local data_service = require(replicatedstorage.Packages.DataService).client;
            local upgrade_utils = require(replicatedstorage.Source.Features.Upgrades.UpgradeServiceUtils);

            local all_upgrades = {};
            for tree_name, tree in pairs(upgrade_tree) do
                for upgrade_id, upgrade_data in pairs(tree) do
                    if upgrade_data.cost then
                        all_upgrades[upgrade_id] = upgrade_data;
                    end;
                end;
            end;

            upgrade_priority_map["All"] = {};
            for id, _ in pairs(all_upgrades) do
                table.insert(upgrade_priority_map["All"], id);
            end;

            while (getgenv().auto_upgrade) and (u_c) and upgradeservice__event do

                local owned_upgrades = data_service:get("upgrades") or {};
                local coins = data_service:get("coins") or 0;
                local roll_currency = data_service:get("rollCurrency") or 0;

                local owned_count = 0;
                local total_count = 0;
                for id, _ in pairs(all_upgrades) do
                    total_count += 1;
                    if upgrade_utils.ownsUpgrade(id, owned_upgrades) then
                        owned_count += 1;
                    end;
                end;
                if getgenv().upgrade_priority_label then
                    getgenv().upgrade_priority_label:ChangeText("Bought: " .. owned_count .. "/" .. total_count .. " upgrades");
                end;

                local priority = getgenv().upgrade_priority or "All";
                local upgrade_list;

                if priority == "All" then
                    upgrade_list = upgrade_priority_map["All"];
                else
                    upgrade_list = upgrade_priority_map[priority] or upgrade_priority_map["All"];
                end;

                local purchased = false;

                for _, upgrade_id in ipairs(upgrade_list) do
                    local upgrade_data = all_upgrades[upgrade_id];
                    if not upgrade_data then continue; end;

                    if upgrade_utils.ownsUpgrade(upgrade_id, owned_upgrades) then continue; end;

                    local dep = upgrade_data.dependency;
                    if dep and dep ~= "originDependency" then
                        if not upgrade_utils.ownsUpgrade(dep, owned_upgrades) then continue; end;
                    end;

                    local currency = upgrade_data.cost.currency;
                    local amount = upgrade_data.cost.amount;

                    local can_afford = false;
                    if currency == "coins" then
                        can_afford = coins >= amount;
                    elseif currency == "rollCurrency" then
                        can_afford = roll_currency >= amount;
                    end;

                    if not can_afford then continue; end;

                    local c_ok = pcall(function()
                        upgradeservice__event:InvokeServer("requestUnlock", upgrade_id);
                    end);

                    if c_ok then
                        purchased = true;
                        task.wait(0.5);
                        break;
                    end;
                end;

                if not purchased then
                    task.wait(5);
                else
                    task.wait(0.5);
                end;
            end;
        end);

        if not ok then
            print("auto_upgrade error:", err);
        end;
    end);
end;

function SLIME:auto_use_boost(a_c)
    a_c = a_c or false;
    local boostservice__event = networker_0_3_1.BoostService.RemoteFunction;

    if not boostservice__event then
        self:client_kick("something unexpected happened with networker path;");
        return;
    end;

    task.spawn(function()
        local ok, err = pcall(function()
            local data_service = require(replicatedstorage.Packages.DataService).client;
            local boost_utils = require(replicatedstorage.Source.Features.Boosts.BoostServiceUtils);
            local server_time = require(replicatedstorage.Source.Core.UI.Sources.serverTimeSource);

            while (getgenv().auto_use_boost) and (a_c) and boostservice__event do

                local boosts = data_service:get("boosts") or {};
                local reconciled = boost_utils.reconcileBoosts(boosts);
                local time = server_time();

                local boost_config = {
                    ["luck"]       = getgenv().auto_boost_luck or false;
                    ["ultraLuck"]  = getgenv().auto_boost_ultra_luck or false;
                    ["currency"]   = getgenv().auto_boost_currency or false;
                    ["rollSpeed"]  = getgenv().auto_boost_roll_speed or false;
                };

                for boost_kind, enabled in pairs(boost_config) do
                    if not enabled then continue; end;

                    local boost_data = reconciled[boost_kind];
                    local is_active = boost_utils.isActive(boost_data, time);
                    local amount = boost_data and boost_data.amount or 0;

                    if not is_active and amount > 0 then
                        pcall(function()
                            boostservice__event:InvokeServer("requestUseBoost", boost_kind);
                        end);
                        task.wait(0.5);
                    end;
                end;

                task.wait(10);
            end;
        end);

        if not ok then
            print("auto_use_boost error:", err);
        end;
    end);
end;

function SLIME:auto_pickup_loot(p_c)
    p_c = p_c or false;

    task.spawn(function()
        local ok, err = pcall(function()
            while (getgenv().auto_pickup_loot) and (p_c) do
                local loot_folder = workspace:FindFirstChild("Loot");
                if loot_folder then
                    for _, item in pairs(loot_folder:GetChildren()) do
                        if not getgenv().auto_pickup_loot then break; end;

                        local is_fruit = false;
                        for _, child in pairs(item:GetChildren()) do
                            local name_lower = child.Name:lower();
                            if name_lower:find("fruit") then
                                is_fruit = true;
                                break;
                            end;
                        end;

                      if is_fruit then
                        local root = item:FindFirstChild("Root") or item:FindFirstChildOfClass("BasePart");
                        if root then
                            pcall(function()
                                local original_cframe = humanoidrootpart.CFrame;
                                getgenv().fruit_teleporting = true;

                                humanoidrootpart.CFrame = root.CFrame + Vector3.new(0, 0, 2);
                                task.wait(0.2);

                                local prompt = nil;
                                for _, desc in pairs(item:GetDescendants()) do
                                    if desc:IsA("ProximityPrompt") then
                                        prompt = desc;
                                        break;
                                    end;
                                end;

                                if prompt then
                                    fireproximityprompt(prompt);
                                    task.wait(0.1);
                                end;

                                humanoidrootpart.CFrame = original_cframe;
                                task.wait(0.1);
                                getgenv().fruit_teleporting = false; 
                            end);
                        end;
                        else
                            local root = item:FindFirstChild("Root") or item:FindFirstChildOfClass("BasePart");
                            if root then
                                pcall(function()
                                    local prompt = nil;
                                    for _, desc in pairs(item:GetDescendants()) do
                                        if desc:IsA("ProximityPrompt") then
                                            prompt = desc;
                                            break;
                                        end;
                                    end;
                                    if prompt then
                                        fireproximityprompt(prompt);
                                    else
                                        firetouchinterest(root, humanoidrootpart, true);
                                        task.wait();
                                        firetouchinterest(root, humanoidrootpart, false);
                                    end;
                                end);
                            end;
                        end;

                        task.wait(0.1);
                    end;
                end;
                task.wait(0.5);
            end;
        end);

        if not ok then
            print("auto_pickup_loot error:", err);
        end;
    end);
end;

