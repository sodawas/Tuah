function SLIME:auto_rebirth(r_c)
    r_c = r_c or false;
    local rebirthservice__event = networker_0_3_1.RebirthService.RemoteFunction;

    if not rebirthservice__event then 
        self:client_kick("something unexpected happened with networker path;");
        return;
    end;

    task.spawn(pcall, function()
        while (getgenv().auto_rebirth) and (r_c) and rebirthservice__event do
            local can_rebirth = false;

            local ok, progress_label = pcall(function()
                return game:GetService("Players").LocalPlayer.PlayerGui.Root.Rebirth.Content.RebirthContent.Footer.RebirthProgressBar:GetChildren()[2].TextLabel;
            end);

            if ok and progress_label then
                local text = progress_label.Text or "";
                local current_str, max_str = text:match("^(.-)%/(.+)$");

                if current_str and max_str then
                    local function parse_value(str)
                        local n = tonumber(str:match("[%d%.]+")) or 0;
                        if str:find("K") then n = n * 1000;
                        elseif str:find("M") then n = n * 1000000; end;
                        return n;
                    end;

                    can_rebirth = parse_value(current_str) >= parse_value(max_str);
                end;
            end;

            if can_rebirth then
                rebirthservice__event:InvokeServer("requestRebirth");
                task.wait();
            else
                task.wait(math.random(10,15));
            end;
        end;
    end);
end;

