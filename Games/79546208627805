local function stripRichText(text)
    return tostring(text or ""):gsub("<.->", "")
end

local function cleanMobKey(name)
    return tostring(name or "")
        :lower()
        :gsub("%s+", "")
        :gsub("s$", "")
end

function LINEAGE:ParseKillObjectiveText(text)
    text = stripRichText(text)

    local mobName, current, max = text:match("Defeat%s+(.-)%s*「%s*(%d+)%s*/%s*(%d+)%s*」")

    if not mobName then
        mobName, current, max = text:match("Defeat%s+(.-)%s*[%(%[]%s*(%d+)%s*/%s*(%d+)%s*[%)%]]")
    end

    if not mobName or not current or not max then
        return nil
    end

    return {
        name = mobName;
        key = cleanMobKey(mobName);
        current = tonumber(current);
        max = tonumber(max);
    }
end

function LINEAGE:GetKillObjectivesFromUI()
    local objectives = {}

    local holder = client.PlayerGui:FindFirstChild("menu")
        and client.PlayerGui.menu:FindFirstChild("task_holder")
        and client.PlayerGui.menu.task_holder:FindFirstChild("holder")
        and client.PlayerGui.menu.task_holder.holder:FindFirstChild("newobjective")
        and client.PlayerGui.menu.task_holder.holder.newobjective:FindFirstChild("ScrollingFrame")
        and client.PlayerGui.menu.task_holder.holder.newobjective.ScrollingFrame:FindFirstChild("holder")

    if not holder then
        return objectives
    end

    local labels = {}

    local single = holder:FindFirstChild("singleobjective")
    if single and single:FindFirstChild("TextLabel") then
        table.insert(labels, single.TextLabel)
    end

    local multi = holder:FindFirstChild("multiobjective")
    if multi then
        local textHolder = multi:FindFirstChild("text")
        if textHolder and textHolder:FindFirstChild("TextLabel") then
            table.insert(labels, textHolder.TextLabel)
        end

        for _, obj in ipairs(multi:GetDescendants()) do
            if obj:IsA("TextLabel") then
                table.insert(labels, obj)
            end
        end
    end

    for _, label in ipairs(labels) do
        local objective = self:ParseKillObjectiveText(label.Text)
        if objective and objective.current < objective.max then
            table.insert(objectives, objective)
        end
    end

    return objectives
end



