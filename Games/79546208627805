        if main_menu then 
            main_menu.Enabled = false;
        end;
    else
        print(" -- Check Failed -- ");
    end;
end;

function BIZARRE:Data()
    local success, response = pcall(function()
        return request({ Url = GIT, Method = "GET" })
    end)

    if (not success) or not response or response.StatusCode ~= 200 then
        self:ClientKick("HTTPGET: Response Failed");
        return false;
    end;

    local body = response.Body;
    local parsed, env = pcall(function()
        local chunk = loadstring("return " .. body);
        return chunk()
    end);

    if not parsed or not env then
        self:ClientKick("HTTPGET: Parse Failed")
        return false;
    end;

    if env.BUILD ~= "Testing" and env.BUILD ~= "Online" then
        self:ClientKick("Lotus is currently not available, for more Information join our Discord!")
        return false;
    end;
    return true;
end;

function BIZARRE:ClientKick(msg)
    msg = msg or "//";

    if typeof(msg) == "string" then
        return client:Kick(msg);
    end;
end;

function BIZARRE:Build()
    local success, response = pcall(function()
        return request({
            Url = GIT,
            Method = "GET"
        })
    end)

    if not success or not response or response.StatusCode ~= 200 then
        return "Unknown";
    end;

    local body = tostring(response.Body or "");

    if string.find(body, "Down") then
        return "Unknown";
    end;

    return "Updated";
end;

function BIZARRE:IsDev()
    return DEVELOPERS[tostring(players.LocalPlayer.UserId)] == true;
end;

function BIZARRE:ProcessBlacklistTimes()
    for userId, entry in pairs(BLACKLIST) do
        local exp = entry.expires;

        if type(exp) == "string" then
            exp = exp:upper()

            if exp == "PERMA" then
                BLACKLIST[userId].expires = "PERMA";
            elseif exp:find("H") then
                local hours = tonumber(exp:match("(%d+)H")) or 0;
                BLACKLIST[userId].expires = os.time() + hours * 3600;
            elseif exp:find("D") then
                local days = tonumber(exp:match("(%d+)D")) or 0;
                BLACKLIST[userId].expires = os.time() + days * 86400;
            end;
        end;
    end;
end;

function BIZARRE:LoadBlacklist()
    local ok, res = pcall(function()
        return request({
            Url = "https://raw.githubusercontent.com/sodawas/Tuah/refs/heads/main/Management/blacklist.json",
            Method = "GET";
        });
    end);

    if not ok or not res or res.StatusCode ~= 200 then
        warn("blacklist request failed;");
        return;
    end;

    local data;
    local success, err = pcall(function()
        data = httpservice:JSONDecode(res.Body);
    end);

    if not success or typeof(data) ~= "table" then
        warn("blacklist JSON decode failed;", err);
        return;
    end;
    BLACKLIST = data;
end;

function BIZARRE:CheckBlacklist()
    local userId = tostring(players.LocalPlayer.UserId);
    local entry = BLACKLIST[userId];

    if not entry then return; end;
    if BIZARRE:IsDev() then return; end;

    local currentTime = os.time();
    local expires = entry.expires;

    if expires == "PERMA" then
        BIZARRE:ClientKick(
            "You have been permanently Blacklisted from using our Services\n" ..
            "Reason: " .. tostring(entry.reason) .. "\n"
        );
        return;
    end;

    if type(expires) == "number" then
        if currentTime < expires then
            local timeLeft = expires - currentTime;
            local days = math.floor(timeLeft / 86400);
            local hours = math.floor((timeLeft % 86400) / 3600);
            BIZARRE:ClientKick(
                "You have been Blacklisted\n" ..
                "Reason: " .. tostring(entry.reason) .. "\n" ..
                "Expires in: " .. days .. " days " .. hours .. " hours"
            )
            return;
        else
            BLACKLIST[userId] = nil;
        end;
    end;
end;

