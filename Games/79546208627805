    ["Data"] = "Data",
    ["Themes"] = "Themes",
};

function Library:Save()
    local folder = "Lotus"
    local sub = tostring(game.PlaceId)
    
    if not isfolder(folder) then makefolder(folder) end
    if not isfolder(folder .. "/" .. sub) then makefolder(folder .. "/" .. sub) end
    
    local path = folder .. "/" .. sub .. "/Data.json"
    
    local data = {}
    for i, v in pairs(self.Created.Flags) do
        if v.Value ~= nil then
            data[i] = v.Value
        end
    end
    
    writefile(path, game:GetService("HttpService"):JSONEncode(data))
    Library:Notify("Config Saved", 3, "Notification")
end

function Library:Load()
    local folder = "Lotus"
    local sub = tostring(game.PlaceId)
    local path = folder .. "/" .. sub .. "/Data.json"
    
    if not isfile(path) then return end
    
    local raw = readfile(path)
    if not raw or raw == "" then return end
    
    local ok, data = pcall(game:GetService("HttpService").JSONDecode, game:GetService("HttpService"), raw)
    if not ok or type(data) ~= "table" then return end
    
    for i, v in pairs(data) do
        if Library.Created.Flags[i] then
            Library.Created.Flags[i]:Load(v)
        end
    end
end

