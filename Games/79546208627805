function Lineage:GetItems()
    local closest;
    local distance = math.huge;

    for i,v in pairs(config.ITEMS.cache) do
        if v and v.Parent then
            local dist = (humanoidrootpart.Position - v.Position).Magnitude;
            if dist < distance then
                distance = dist;
                closest = v;
            end;
        else
            config.ITEMS.cache[i] = nil;
        end;
    end;

    return closest;
end;

function Lineage:CollectItems()
    local item = Lineage:GetItems();
    if not item then return; end;

    local distance = (humanoidrootpart.Position - item.Position).Magnitude;
    local tween = tweenservice:Create(
        humanoidrootpart,
        TweenInfo.new(distance / math.huge, Enum.EasingStyle.Linear),
        {CFrame = item.CFrame + Vector3.new(0,2,0)}
    );
    tween:Play();
    tween.Completed:Wait();

    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true) or item.Parent:FindFirstChildWhichIsA("ProximityPrompt", true);
    if prompt then
        fireproximityprompt(prompt);
        setproximitypromptduration(prompt, 0.01)
    end;
end;

