function Lineage:TalkToNPC(npcName)
    local npc = self:FindNPCInWorkspace(npcName)

    if not npc then
        local pos = NPC_POSITIONS[npcName]
        if pos and humanoidrootpart then
            humanoidrootpart.CFrame = CFrame.new(pos)
            task.wait(1)
            npc = self:FindNPCInWorkspace(npcName)
        end;
    end;

    if not npc then
        return false;
    end;

    local root = npc:FindFirstChild("HumanoidRootPart")
        or npc:FindFirstChildWhichIsA("BasePart")

    if root and humanoidrootpart then
        humanoidrootpart.CFrame = CFrame.new(root.Position + root.CFrame.LookVector * -3, root.Position)
        task.wait(0.5);
    end;

    pcall(function()
        replicatedstorage.requests.character.dialogue:FireServer(npc, 1)
    end)

    local dialogueGui = client.PlayerGui:WaitForChild("Dialogue", 5);
    if dialogueGui then
        local holder = dialogueGui:WaitForChild("Holder", 5)
        if holder then
            holder:WaitForChild("Choices", 5);
        end;
    end;
    task.wait(0.5);

    local maxSteps = 12;
    for step = 1, maxSteps do
        local option = self:GetDialogueFirstOption()

        if not option then
            task.wait(0.3)
            option = self:GetDialogueFirstOption()
            if not option then break end;
        end;

        pcall(function()
            replicatedstorage.requests.character.dialogue:FireServer(npc, option)
        end)

        task.wait(0.6);
    end;
    return true;
