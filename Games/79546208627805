        end;
    end;

    local multi = holder:FindFirstChild("multiobjective")
    if multi then
        for _, child in ipairs(multi:GetChildren()) do
            local label = child:FindFirstChild("TextLabel") 
                or (child:FindFirstChildWhichIsA("TextLabel"))
            if label and label.Text ~= "" then
                local mobName, current, max = label.Text:match("Defeat%s+(.-)%s*[「「(「(](%d+)/(%d+)")
                if mobName and max then
                    requirements[mobName] = tonumber(max);
                end;
            end;
        end;

        local textHolder = multi:FindFirstChild("text")
        if textHolder then
            local label = textHolder:FindFirstChild("TextLabel")
            if label and label.Text ~= "" then
                local mobName, current, max = label.Text:match("Defeat%s+(.-)%s*[「「(「(](%d+)/(%d+)")
                if mobName and max then
                    requirements[mobName] = tonumber(max);
                end;
            end;
        end;
    end;

    return requirements;
end;

