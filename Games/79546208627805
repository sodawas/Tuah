function Lineage:CheckEscape()
    if not config.PVP.escape_enabled then return false end;
    if not humanoid or not humanoidrootpart then return false end;

    local hpPercent = (humanoid.Health / humanoid.MaxHealth) * 100;

    if hpPercent <= config.PVP.escape_hp then
        local angle = math.random() * math.pi * 2;
        local dist = config.PVP.safe_distance;
        local escapePos = humanoidrootpart.Position + Vector3.new(
            math.cos(angle) * dist,
            0,
            math.sin(angle) * dist
        );
        humanoidrootpart.CFrame = CFrame.new(escapePos);
        Library:Notify("Low HP! Escaped to safety!", 3, "PvP");
        return true;
    end;
    return false;
end;


local ANTI_TS_RANGE = 25;
local ANTI_TS_DELAY = 0.8;
local ANTI_TS_OFFSET = Vector3.new(800, 1000, 500);
function Lineage:AntiTimestop()
    return workspace.Live.DescendantAdded:Connect(function(descendant)
        if not getgenv().anti_timestop then return; end;
        if descendant.Name ~= "TimeStopping" or descendant.Name ~= "Timestop" then return; end;

        local model = descendant.Parent;
        if not model then return; end;
        if players:GetPlayerFromCharacter(model) then return; end;

        local root = model:FindFirstChild("HumanoidRootPart");
        if not root or not humanoidrootpart then return; end;

        local dist = (humanoidrootpart.Position - root.Position).Magnitude;
        if dist > ANTI_TS_RANGE then return; end;

        local savedPos = humanoidrootpart.CFrame;
        humanoidrootpart.CFrame = CFrame.new(humanoidrootpart.Position + ANTI_TS_OFFSET);

        task.wait(ANTI_TS_DELAY);

        if humanoidrootpart then
            humanoidrootpart.CFrame = savedPos;
        end;
    end);
end;

