function LINEAGE:KillMobForQuest(quest)
    local killTimeout = tick() + 300

    while storyRunning and tick() < killTimeout do
        runservice.Heartbeat:Wait()

        local currentQuest = nil;
        local ok, freshData = pcall(function()
            return httpservice:JSONDecode(client.PlayerData.SlotData.CurrentQuests.Value)
        end)
        if ok and type(freshData) == "table" then
            for _, q in ipairs(freshData) do
                if q.Name == quest.Name then
                    currentQuest = q;
                    break;
                end;
            end;
        end;

        if not currentQuest or not currentQuest.Kills then break end;
        local objectives = self:GetKillObjectivesFromUI()
        local pendingMobs = {}

        if #objectives > 0 then
            for _, objective in ipairs(objectives) do
                table.insert(pendingMobs, objective.name)
            end
        else
            for mobName, _ in pairs(currentQuest.Kills) do
                table.insert(pendingMobs, mobName)
            end
        end



        if #pendingMobs == 0 then
            break;
        end;

        local bestTarget = nil;
        local shortest = math.huge;
        for _, model in ipairs(workspace.Live:GetChildren()) do
            if players:GetPlayerFromCharacter(model) then continue end;

            local hum = model:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then continue end;

            local root = model:FindFirstChild("HumanoidRootPart")
            if not root then continue end;

            local cleanModel = cleanMobKey(model.Name)


            for _, mobName in ipairs(pendingMobs) do
                local cleanTarget = cleanMobKey(mobName)
                if cleanModel:find(cleanTarget) then
                    local dist = (humanoidrootpart.Position - root.Position).Magnitude
                    if dist < shortest then
                        shortest = dist;
                        bestTarget = model;
                    end;
                    break;
                end;
            end;
        end;

        if bestTarget then
            self:EnableStand()
            self:TeleportToMob(bestTarget)
            self:M1()
            local controller = workspace.Live[client.Name] and
                workspace.Live[client.Name]:FindFirstChild("client_character_controller")
            if controller then
                for _, key in ipairs({"E", "R", "Z"}) do
                    pcall(function()
                        controller.Skill:FireServer(key, true)
                    end)
                end;
            end;
        else
    local rendered = false

    for _, mobName in ipairs(pendingMobs) do
        if self:RenderQuestMob(mobName) then
            rendered = true
            break
        end
    end

    if not rendered then
        task.wait(0.3)
            end
        end;
    end;
end;

