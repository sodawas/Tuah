local function getPvpTarget()
    if not pvpTarget or pvpTarget == "None" then return nil end;
    local plr = players:FindFirstChild(pvpTarget);
    if not plr or not plr.Character then return nil end;
    local root = plr.Character:FindFirstChild("HumanoidRootPart");
    if not root then return nil end;
    return plr.Character;
end;

local function teleportToPvpTarget(char)
    if not char or not humanoidrootpart then return end;
    local root = char:FindFirstChild("HumanoidRootPart");
    if not root then return end;

    local mode = config.FARM.teleport.mode;
    local offset = config.FARM.teleport.offset;
    local targetPosition;

    if mode == "Behind" then
        targetPosition = root.Position + (root.CFrame.LookVector * -offset);
    elseif mode == "Below" then
        targetPosition = root.Position - Vector3.new(0, offset, 0);
    elseif mode == "Above" then
        targetPosition = root.Position + Vector3.new(0, offset, 0);
    else
        targetPosition = root.Position + (root.CFrame.LookVector * -offset);
    end;

    humanoidrootpart.CFrame = CFrame.new(targetPosition, root.Position);
end;

