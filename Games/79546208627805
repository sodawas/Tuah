local dashFuncs = {};
for _, func in ipairs(getgc(true)) do
    if type(func) == "function" then
        local ok, info = pcall(debug.getinfo, func);
        if not ok then continue end;
        if info and info.name == "dash" and info.short_src:find("client_character_controller") then
            table.insert(dashFuncs, func);
        end;
    end;
end;

local hooked = false;
local No_Dash_Cooldown; No_Dash_Cooldown = Sections.Other_Misc:CreateToggle({
    Text = "No Dash Cooldown";
    Alignment = "Left";
    Default = false;
    Callback = function(val)
        if val and not hooked then
            hooked = true;
            for i, dashFunc in ipairs(dashFuncs) do
                local OldDash; OldDash = hookfunction(dashFunc, function(...)
                    debug.setupvalue(dashFunc, 3, false);
                    return OldDash(...);
                end);
            end;
        elseif not val and hooked then
            hooked = false;
            for _, dashFunc in ipairs(dashFuncs) do
                pcall(restorefunction, dashFunc);
            end;
        end;
    end;
    Flag = "no_dash_cd";
});

