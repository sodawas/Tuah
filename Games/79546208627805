    function LINEAGE:Tween_To_Mob(mob)
        if not mob then return; end;

        local root = mob:FindFirstChild("HumanoidRootPart")
        if not root then return; end;

        local padding = 4;
        local behindOffset = root.CFrame.LookVector * -padding;
        local targetPosition = root.Position + behindOffset;
        local targetCFrame = CFrame.new(targetPosition, root.Position);
        local distance = (humanoidrootpart.Position - targetPosition).Magnitude;

        if distance < 1.5 then
            return;
        end;

        local tween = tweenservice:Create(
            humanoidrootpart,
            TweenInfo.new(distance / 40, Enum.EasingStyle.Linear),
            {CFrame = targetCFrame}
        )
        tween:Play()
    end;

    function LINEAGE:TeleportToMob(mob)
        if not mob then return; end;

        local root = mob:FindFirstChild("HumanoidRootPart");
        if not root then return; end;

        local mode = config.FARM.teleport.mode;
        local offset = config.FARM.teleport.offset;
        local targetPosition;

        if mode == "Behind" then
            targetPosition = root.Position + (root.CFrame.LookVector * -offset);
        elseif mode == "Below" then
            targetPosition = root.Position - Vector3.new(0, offset, 0);
        elseif mode == "Above" then
            targetPosition = root.Position + Vector3.new(0, offset, 0);
        end;

        humanoidrootpart.CFrame = CFrame.new(targetPosition, root.Position);
    end;

