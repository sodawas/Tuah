            local slotData = client.PlayerData.SlotData;
            local playerData = client.PlayerData;
            local level = slotData.Level.Value;
            local prestige = slotData.Prestige.Value;
            local family = slotData.Family.Value;
            local gang = playerData.Gang.Value;

            Label_Level:ChangeText("Level: " .. tostring(level));
            Label_Prestige:ChangeText("Prestige: " .. tostring(prestige));
            Label_Family:ChangeText("Family: " .. tostring(family));
            Label_Gang:ChangeText("Gang: " .. (gang ~= "" and gang or "None"));

            local standRaw = slotData.Stand.Value;
            if standRaw and standRaw ~= "" then
                local ok, standData = pcall(httpservice.JSONDecode, httpservice, standRaw);
                if ok and standData then
                    Label_Stand:ChangeText("Stand: " .. tostring(standData.Name or "None"));
                    Label_StandStats:ChangeText(
                        "Str: " .. tostring(standData.Strength or "?") ..
                        " | Spd: " .. tostring(standData.Speed or "?") ..
                        " | Spe: " .. tostring(standData.Specialty or "?") ..
                        " | Trait: " .. tostring(standData.Trait or "?")
                    );

                    local conjRaw = playerData.Conjuration.Value;
                    if conjRaw and conjRaw ~= "" then
                        local ok2, conjData = pcall(httpservice.JSONDecode, httpservice, conjRaw);
                        if ok2 and conjData and standData.Name then
