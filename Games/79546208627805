end;

function Bizzare:ProcessBlacklistTimes()
    for userId, entry in pairs(Blacklist) do
        local exp = entry.expires;

        if type(exp) == "string" then
            exp = exp:upper()

            if exp == "PERMA" then
                Blacklist[userId].expires = "PERMA";
            elseif exp:find("H") then
                local hours = tonumber(exp:match("(%d+)H")) or 0;
                Blacklist[userId].expires = os.time() + hours * 3600;
            elseif exp:find("D") then
                local days = tonumber(exp:match("(%d+)D")) or 0;
                Blacklist[userId].expires = os.time() + days * 86400;
            end;
        end;
    end;
end;

function Bizzare:LoadBlacklist()
    local ok, res = pcall(function()
        return request({
            Url = "https://raw.githubusercontent.com/sodawas/Tuah/refs/heads/main/Management/blacklist.json",
            Method = "GET";
        });
    end);

    if not ok or not res or res.StatusCode ~= 200 then
        warn("blacklist request failed;");
        return;
    end;

    local data;
    local success, err = pcall(function()
        data = httpservice:JSONDecode(res.Body);
    end);

    if not success or typeof(data) ~= "table" then
        warn("blacklist JSON decode failed;", err);
        return;
    end;
    Blacklist = data;
end;

function Bizzare:CheckBlacklist()
    local userId = tostring(players.LocalPlayer.UserId);
    local entry = Blacklist[userId];

    if not entry then return; end;
    if Bizzare:IsDev() then return; end;

    local currentTime = os.time();
    local expires = entry.expires;

    if expires == "PERMA" then
        Bizzare:ClientKick(
            "You have been permanently Blacklisted from using our Services\n" ..
            "Reason: " .. tostring(entry.reason) .. "\n"
        );
        return;
    end;

    if type(expires) == "number" then
        if currentTime < expires then
            local timeLeft = expires - currentTime;
            local days = math.floor(timeLeft / 86400);
            local hours = math.floor((timeLeft % 86400) / 3600);
            Bizzare:ClientKick(
                "You have been Blacklisted\n" ..
                "Reason: " .. tostring(entry.reason) .. "\n" ..
                "Expires in: " .. days .. " days " .. hours .. " hours"
            )
            return;
        else
            Blacklist[userId] = nil;
        end;
    end;
end;

