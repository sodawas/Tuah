do --:: PVP - PvP Tab ::--
    function LINEAGE:PvP_Teleport(mob)
        if not mob then 
            return 
        end;

        local root = mob:FindFirstChild("HumanoidRootPart");
        if not root then 
            return 
        end;

        local mode = config.FARM.teleport.mode;
        local offset = config.FARM.teleport.offset;
        local velocity = root.AssemblyLinearVelocity;
        local predictedPos = root.Position + (velocity * 0.1);

        local targetPosition;
        if mode == "Behind" then
            targetPosition = predictedPos + (root.CFrame.LookVector * -offset);
        elseif mode == "Below" then
            targetPosition = predictedPos - Vector3.new(0, offset, 0);
        elseif mode == "Above" then
            targetPosition = predictedPos + Vector3.new(0, offset, 0);
        end;

        humanoidrootpart.CFrame = CFrame.new(targetPosition, predictedPos);
    end;
end;

