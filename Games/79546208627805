        and client.PlayerGui.menu.task_holder:FindFirstChild("holder")
        and client.PlayerGui.menu.task_holder.holder:FindFirstChild("newobjective")
        and client.PlayerGui.menu.task_holder.holder.newobjective:FindFirstChild("ScrollingFrame")
        and client.PlayerGui.menu.task_holder.holder.newobjective.ScrollingFrame:FindFirstChild("holder")

    if not holder then return objectives end

