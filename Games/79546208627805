    function LINEAGE:Send_Webhook(data)
        if not config.WEBHOOK.enabled then 
            return false, "webhook disabled;"
        end;

        if not config.WEBHOOK.url or config.WEBHOOK.url == "" then 
            return false, "webhook url missing;"
        end;

        if typeof(data) ~= "table" then
            return false, "expected table;"
        end;

        local pool = {
            username = config.WEBHOOK.username or "Lotus Notifier";
            avatar_url = config.WEBHOOK.avatar or "";
            content = data.content or nil;
            embeds = data.embeds or nil;
        };

        local success, response = pcall(function()
            return request(
                {
                    Url = config.WEBHOOK.url;
                    Method = "POST";
                    Headers = {
                        ["Content-Type"] = "application/json"
                    };
                    Body = httpservice:JSONEncode(pool)
                }
            )
        end);

        if not success then 
            return false, "webhook request failed;"
        end;

        if response and (response.StatusCode == 204 or response.StatusCode == 200) then 
            return true, response
        else
            return false, response
        end;
    end;

    function LINEAGE:GetStandInfo()
        local standValue = client:WaitForChild("PlayerData"):WaitForChild("SlotData"):WaitForChild("Stand").Value;

        if not standValue or standValue == "" then 
            print("no stand data ####1");
            return nil;
        end;

        local standData = httpservice:JSONDecode(standValue);
        local standCatalog = get_data_remote:InvokeServer("stand");
        local skinCatalog  = get_data_remote:InvokeServer("stand_skin");
        local traitCatalog = get_data_remote:InvokeServer("trait");
        local traitRarity = traitCatalog[standData.Trait] and traitCatalog[standData.Trait].Rarity or "N/A";
        local skinRarity = "None";

        if standData.Skin then
            local skins = skinCatalog[standData.Name];
            skinRarity = (skins and skins[standData.Skin]) or "Common";
        end;

        return {
            name = standData.Name;
            trait = standData.Trait;
            traitRarity = traitRarity;
            strength = standData.Strength;
            speed = standData.Speed;
            specialty = standData.Specialty;
            skin = standData.Skin or "None";
            skinRarity = skinRarity;
        };
    end;

    local lastStand = nil;
    function LINEAGE:NotifyStand(info)
        if not info then return end;

        local current = info.name .. info.trait .. info.strength .. info.speed .. info.specialty
        if current == lastStand then
            return;
        end;
        lastStand = current;

        local text =
            "Stand: " .. info.name .. "\n" ..
            "Trait: " .. info.trait .. " (" .. info.traitRarity .. ")\n" ..
            "Skin: " .. info.skin .. " (" .. info.skinRarity .. ")\n" ..
            "Stats: " .. info.strength .. " / " .. info.speed .. " / " .. info.specialty
        Library:Notify(text, 5, "Stand Roll");
    end;

    function LINEAGE:CheckStandConditions(info)
        if not info then return false, nil; end;

        print("[STAND] Checking: " .. tostring(info.name) .. " | Skin: " .. tostring(info.skinRarity) .. " | Trait: " .. tostring(info.traitRarity));

        local hasStandFilter = #config.STAND.selected_stands > 0;
        local hasTraitFilter = #config.STAND.selected_trait_rarity > 0 or #config.STAND.selected_trait_names > 0;
        local hasSkinFilter = #config.STAND.selected_skin_rarity > 0;
        local hasStatFilter = #config.STAND.stat_combo > 0;

        print("[STAND] Filters - Stand: " .. tostring(hasStandFilter) .. " | Trait: " .. tostring(hasTraitFilter) .. " | Skin: " .. tostring(hasSkinFilter) .. " | Stat: " .. tostring(hasStatFilter));
        print("[STAND] Selected stands: " .. tostring(#config.STAND.selected_stands));
        for _, s in ipairs(config.STAND.selected_stands) do
            print("[STAND] -> " .. tostring(s));
        end;

        local standHit = false;
        if hasStandFilter then
            if table.find(config.STAND.selected_stands, info.name) then
                standHit = true;
                print("[STAND] Stand matched: " .. info.name);
            else
                print("[STAND] Stand NOT matched: " .. info.name .. " not in list");
                return false, nil;
            end;
        end;

        if hasStandFilter and not hasTraitFilter and not hasSkinFilter and not hasStatFilter then
            print("[STAND] Only stand filter active → STOP");
            return true, "Stand matched";
        end;

        print("[STAND] No match condition met → continue");
        return false, nil;
    end;

    function LINEAGE:SendStandWebhook(info, reason)
        if not config.WEBHOOK.enabled or not config.WEBHOOK.stand then return; end;

        local embed = {
            title = "🟢 **: Stand Recieved :**",
            description = "**" .. info.name .. "**",
            color = 0x00ff88,
            fields = {
                { name = "Trait", value = info.trait .. " (`" .. info.traitRarity .. "`)", inline = true },
                { name = "Skin", value = info.skin .. " (`" .. info.skinRarity .. "`)", inline = true },
                { name = "Stats", value = "Strength: `" .. (statMap[info.strength] or info.strength) .. "`\n" .. "Speed: `" .. (statMap[info.speed] or info.speed) .. "`\n" .. "Specialty: `" .. (statMap[info.specialty] or info.specialty) .. "`", inline = false },
                { name = "Reason", value = "```" .. (reason or "Filter matched") .. "```", inline = false }
            },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
            footer = { text = "Lotus Stand System" }
        };

        LINEAGE:Send_Webhook({
            embeds = { embed };
            content = "@everyone Good Stand Pull!"
        });
    end;

    getgenv().standFarming = false;
    function LINEAGE:StartStandFarm()
        if getgenv().standFarming then 
            return; 
        end;

        getgenv().standFarming = true;
        task.spawn(function()
            local lastArrow = 0;
            local ARROW_CD = 5;

            while getgenv().standFarming and config.STAND.enabled do
                local info = self:GetStandInfo();

                if info then
                    self:NotifyStand(info);
                end;

                if info then
                    local hit, reason = self:CheckStandConditions(info);
                    if hit then
                        getgenv().standFarming = false;
                        config.STAND.enabled = false;
                        self:SendStandWebhook(info, reason);
                        Library:Notify(
                            "Stand: "..info.name..
                            "\nTrait: "..info.trait..
                            "\nStats: "..statMap[info.strength]..","..statMap[info.speed]..","..statMap[info.specialty],
                            5,
                            "Stand Found"
                        );
                        break;
                    end;

                    if tick() - lastArrow >= ARROW_CD then
                        use_item_remote:FireServer("Stand Arrow");
                        lastArrow = tick();
                    end;
                end;
                task.wait(2);
            end;
            getgenv().standFarming = false;
        end);
    end;
end;

