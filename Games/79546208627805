function Lineage:GetQuestType(quest)
    if not quest then return nil, nil end;

    if quest.Talk then
        local pendingTalks = {};
        for npcName, done in pairs(quest.Talk) do
            if not done then
                table.insert(pendingTalks, npcName);
            end;
        end;

        if #pendingTalks > 0 then
            return "Talk", pendingTalks;
        end;
    end;

    if quest.Kills then
        for mobName, count in pairs(quest.Kills) do
            if RAID_MOBS[mobName] then
                return "RaidKill", mobName
            end;
        end;
        for mobName, count in pairs(quest.Kills) do
            return "Kill", mobName, count
        end;
    end;

    if quest.Raids ~= nil then
        return "Raid", nil
    end;

    return nil, nil;
end;

