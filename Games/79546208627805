function LINEAGE:ParseTalkObjectiveText(text)
    local raw = tostring(text or "")

    if raw:lower():find("<s>") then
        return nil
    end

    text = stripRichText(raw):gsub("^%s+", ""):gsub("%s+$", "")

    local npcName =
        text:match("^Talk%s+to:%s*(.+)$")
        or text:match("^Talk%s+to%s+(.+)$")
        or text:match("^Speak%s+to:%s*(.+)$")
        or text:match("^Speak%s+to%s+(.+)$")
        or text:match("^Talk%s+with:%s*(.+)$")
        or text:match("^Talk%s+with%s+(.+)$")

    if not npcName then
        return nil
    end

    npcName = npcName:gsub("「.-」", ""):gsub("%(.-%)", "")
    npcName = npcName:gsub("^%s+", ""):gsub("%s+$", "")

    if npcName == "" then
        return nil
    end

    return {
        name = npcName;
        current = 0;
        max = 1;
    }
end


