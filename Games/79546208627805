function LINEAGE:InstakillWithGrab(target)
    if not target or not humanoidrootpart then return end;
    local root = target:FindFirstChild("HumanoidRootPart");
    if not root then return end;

    humanoidrootpart.CFrame = CFrame.new(root.Position + Vector3.new(0, 0, -2), root.Position);
    task.wait(0.1);

    local ok, controller = pcall(function()
        return workspace.Live[client.Name].client_character_controller;
    end);
    if ok and controller then
        pcall(function()
            controller.Skill:FireServer(config.INSTAKILL.grab_skill, true);
        end);
    end;

    local timeout = tick() + 2;
    repeat
        task.wait(0.05);
    until grabActive or tick() > timeout;

    if grabActive then
        task.spawn(function()
            getgenv().auto_raid_farm = false;
            getgenv().raidFarming = false;
            
            local highPos = Vector3.new(
                humanoidrootpart.Position.X,
                -470,
                humanoidrootpart.Position.Z
            );

            humanoidrootpart.CFrame = CFrame.new(highPos);
            task.wait(0.2);

            local floor = Instance.new("Part");
            floor.Size = Vector3.new(10, 1, 10);
            floor.Anchored = true;
            floor.CanCollide = true;
            floor.Transparency = 1;
            floor.CFrame = CFrame.new(highPos - Vector3.new(0, 3, 0));
            floor.Parent = workspace;

            while grabActive and humanoid and humanoid.Health > 0 do
                humanoidrootpart.CFrame = CFrame.new(highPos);
                floor.CFrame = CFrame.new(highPos - Vector3.new(0, 3, 0));
                runservice.Heartbeat:Wait();
            end;

            floor:Destroy();

            local waitTime = math.random(15, 20);
            Library:Notify("Void TP erkannt, warte " .. waitTime .. "s...", waitTime, "Instakill");
            task.wait(waitTime);

            local bossStillAlive = false;
            local boss = LINEAGE:GetRaidBoss();
            if boss then
                local bossHum = boss:FindFirstChildOfClass("Humanoid");
                if bossHum and bossHum.Health > 0 then
                    bossStillAlive = true;
                end;
            end;

            local inVoid = humanoidrootpart and humanoidrootpart.Position.Y < -400;

            if inVoid or bossStillAlive then
                Library:Notify("Raid läuft noch, starte Farm neu...", 3, "Instakill");
                getgenv().auto_raid_farm = true;
                getgenv().raidFarming = false;
                task.wait(0.1);
                LINEAGE:StartRaidFarm();
                LINEAGE:StartInstakillLoop();
            end;

            task.wait();
            local landingFloor = Instance.new("Part");
            landingFloor.Size = Vector3.new(50, 50, 50);
            landingFloor.Anchored = true;
            landingFloor.CanCollide = true;
            landingFloor.Transparency = 1;
            landingFloor.CFrame = CFrame.new(humanoidrootpart.Position - Vector3.new(0, 3, 0));
            landingFloor.Parent = workspace;
        end);
    else
        Library:Notify("Kein Grab - weiter...", 2, "Instakill");
    end;
end;

function LINEAGE:StartInstakillLoop()
    task.spawn(function()
        while getgenv().auto_raid_farm do
            runservice.Heartbeat:Wait();

            if not config.INSTAKILL.enabled then
                task.wait(0.5);
                continue;
            end;

            local boss = self:GetRaidBoss();
            if not boss then 
                task.wait(0.3); 
                continue; 
            end;

            local hum = boss:FindFirstChildOfClass("Humanoid");
            if not hum or hum.Health <= 0 then 
                task.wait(0.3); 
                continue; 
            end;

            local hpPercent = (hum.Health / hum.MaxHealth) * 100;
            if hpPercent <= config.INSTAKILL.threshold then

                if grabActive then
                    self:InstakillWithGrab(boss);
                    task.wait(2);
                else
                    self:TeleportToMob(boss);
                    local ok, controller = pcall(function()
                        return workspace.Live[client.Name].client_character_controller;
                    end);
                    if ok and controller then
                        pcall(function()
                            controller.Skill:FireServer(config.INSTAKILL.grab_skill, true);
                        end);
                        task.wait(config.INSTAKILL.cast_delay or 1);
                        
                        pcall(function()
                            controller.Skill:FireServer(config.INSTAKILL.grab_skill, true);
                        end);
                    end;
                    task.wait(0.5);
                end;
            end;
        end;
    end);
end;

