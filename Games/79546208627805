    local holder = gui:FindFirstChild("menu")
        and gui.menu:FindFirstChild("task_holder")
        and gui.menu.task_holder:FindFirstChild("holder")
        and gui.menu.task_holder.holder:FindFirstChild("newobjective")
        and gui.menu.task_holder.holder.newobjective:FindFirstChild("ScrollingFrame")
        and gui.menu.task_holder.holder.newobjective.ScrollingFrame:FindFirstChild("holder")

    if not holder then 
        return requirements;
    end;

    local single = holder:FindFirstChild("singleobjective")
    if single then
        local label = single:FindFirstChild("TextLabel")
        if label and label.Text ~= "" then
            local mobName, current, max = label.Text:match("Defeat%s+(.-)%s*[「「(「(](%d+)/(%d+)")
            if mobName and max then
                requirements[mobName] = tonumber(max);
