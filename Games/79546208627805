function Lineage:Send_Webhook(data)
    if not config.WEBHOOK.enabled then 
        return false, "webhook disabled;"
    end;

    if not config.WEBHOOK.url or config.WEBHOOK.url == "" then 
        return false, "webhook url missing;"
    end;

    if typeof(data) ~= "table" then
        return false, "expected table;"
    end;

    local pool = {
        username = config.WEBHOOK.username or "Lotus Notifier";
        avatar_url = config.WEBHOOK.avatar or "";
        content = data.content or nil;
        embeds = data.embeds or nil;
    };
    local success, response = pcall(function()
        return request(
            {
                Url = config.WEBHOOK.url;
                Method = "POST";
                Headers = {
                    ["Content-Type"] = "application/json"
                };
                Body = httpservice:JSONEncode(pool)
            }
        )
    end);

    if not success then 
        return false, "webhook request failed;"
    end;

    if response and (response.StatusCode == 204 or response.StatusCode == 200) then 
        return true, response
    else
        return false, response
    end;
end;

