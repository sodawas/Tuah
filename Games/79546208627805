        Data_Label_SubAbility:ChangeText("Sub Ability: " .. tostring(sd.SubAbility.Value));
        Data_Label_Edict:ChangeText("Edict: " .. tostring(sd.Edict.Value));

        local rawTime = pd.TimeSpentInGame.Value;
        Data_Label_Time:ChangeText("Time Ingame: " .. formatTime(rawTime));

        local standRaw = sd.Stand.Value;
        if standRaw and standRaw ~= "" then
            local ok, standData = pcall(httpservice.JSONDecode, httpservice, standRaw);
            if ok and standData then
                Data_Label_Stand:ChangeText("Stand: " .. tostring(standData.Name or "—"));
                Data_Label_Trait:ChangeText("Trait: " .. tostring(standData.Trait or "—"));
                Data_Label_Skin:ChangeText("Skin: " .. tostring(standData.Skin or "None"));
                Data_Label_Str:ChangeText("Strength: " .. tostring(statMap[standData.Strength] or standData.Strength or "—"));
                Data_Label_Spd:ChangeText("Speed: " .. tostring(statMap[standData.Speed] or standData.Speed or "—"));
                Data_Label_Spe:ChangeText("Specialty: " .. tostring(statMap[standData.Specialty] or standData.Specialty or "—"));
            end;
        else
            Data_Label_Stand:ChangeText("Stand: None");
        end;

        Data_Log_Products:Clear();
        local productsRaw = pd.OwnedProducts.Value;
        if productsRaw and productsRaw ~= "" then
            local ok2, products = pcall(httpservice.JSONDecode, httpservice, productsRaw);
            if ok2 and products then
                local found = false;
                for id, _ in pairs(products) do
                    local name = GAMEPASS_NAMES[tostring(id)] or ("ID: " .. tostring(id));
                    Data_Log_Products:AddEntry("✅ " .. name);
                    found = true;
                end;
                if not found then
                    Data_Log_Products:AddEntry("No Gamepasses owned");
                end;
            end;
        else
            Data_Log_Products:AddEntry("No Gamepasses owned");
        end;

Data_Log_Inventory:Clear();
local inventoryRaw = sd.Inventory.Value;
if inventoryRaw and inventoryRaw ~= "" then
    local ok3, items = pcall(httpservice.JSONDecode, httpservice, inventoryRaw);
    if ok3 and items then
        local typeFilter = config.DATA.inventory_type_filter or "All";
        local rarityFilter = config.DATA.inventory_filter or {};

        local stackCount = 0;
        local equipCount = 0;

        for _, item in ipairs(items) do
            local isLocked = item.Locked == true;
            local isEquip = item.ID ~= nil;
            local isStack = item.Amount ~= nil;

            if typeFilter == "Equipment" and not isEquip then continue end;
            if typeFilter == "Stackable" and not isStack then continue end;
            if typeFilter == "Locked" and not isLocked then continue end;

            if #rarityFilter > 0 and item.Rarity then
                if not table.find(rarityFilter, item.Rarity) then continue end;
            end;

            if isStack then
                stackCount += 1;
                local lockedStr = isLocked and " 🔒" or "";
                Data_Log_Inventory:AddEntry("📦 " .. tostring(item.Name) .. "  x" .. tostring(item.Amount) .. lockedStr);
            elseif isEquip then
                equipCount += 1;
                local pipStr = "";
                if item.Pips and #item.Pips > 0 then
                    pipStr = "  [" .. table.concat(item.Pips, " | ") .. "]";
                end;
                local lockedStr = isLocked and " 🔒" or "";
                Data_Log_Inventory:AddEntry("🎽 " .. tostring(item.Name) .. pipStr .. lockedStr);
            end;
        end;

        Data_Log_Inventory:AddEntry("──────────────────");
        Data_Log_Inventory:AddEntry("📊 Equipment: " .. equipCount .. "  |  Stackable: " .. stackCount);
    end;
else
    Data_Log_Inventory:AddEntry("Inventory empty");
end;

