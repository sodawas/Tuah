function Lineage:GetStandInfo()
    local standValue = client:WaitForChild("PlayerData"):WaitForChild("SlotData"):WaitForChild("Stand").Value;

    if not standValue or standValue == "" then 
        print("no stand data ####1")
        return nil; 
    end;

    local standData = httpservice:JSONDecode(standValue);
    local standCatalog = get_data_remote:InvokeServer("stand");
    local skinCatalog  = get_data_remote:InvokeServer("stand_skin");
    local traitCatalog = get_data_remote:InvokeServer("trait");
    local traitRarity = traitCatalog[standData.Trait] and traitCatalog[standData.Trait].Rarity or "N/A";
    local skinRarity = "None";

    if standData.Skin then
        local skins = skinCatalog[standData.Name];
        skinRarity = (skins and skins[standData.Skin]) or "Common";
    end;

    return {
        name = standData.Name;
        trait = standData.Trait;
        traitRarity = traitRarity;
        strength = standData.Strength;
        speed = standData.Speed;
        specialty = standData.Specialty;
        skin = standData.Skin or "None";
        skinRarity = skinRarity;
    };
end;

local lastStand = nil;
function Lineage:NotifyStand(info)
    if not info then return end;

    local current = info.name .. info.trait .. info.strength .. info.speed .. info.specialty
    if current == lastStand then
        return;
    end;
    lastStand = current;

    local text =
        "Stand: " .. info.name .. "\n" ..
        "Trait: " .. info.trait .. " (" .. info.traitRarity .. ")\n" ..
        "Skin: " .. info.skin .. " (" .. info.skinRarity .. ")\n" ..
        "Stats: " .. info.strength .. " / " .. info.speed .. " / " .. info.specialty
    Library:Notify(text, 5, "Stand Roll");
end;

function Lineage:CheckStandConditions(info)
    if not info then 
        print("no info ####1")
        return false, nil; 
    end;

    local mode = config.STAND.config_mode;
    local hitReasons = {};

    if #config.STAND.selected_stands > 0 then
        if not table.find(config.STAND.selected_stands, info.name) then
            return false, nil;
        end;
    end;

    local traitHit = false;
    if #config.STAND.selected_trait_rarity > 0 then
        if table.find(config.STAND.selected_trait_rarity, info.traitRarity) then
            traitHit = true;
        end;
    end;

    if #config.STAND.selected_trait_names > 0 then
        if table.find(config.STAND.selected_trait_names, info.trait) then
            traitHit = true;
        end;
    end;

    if traitHit then
        table.insert(hitReasons, "Trait OK");
    end;

    local skinHit = false;
    if #config.STAND.selected_skin_rarity > 0 then
        if table.find(config.STAND.selected_skin_rarity, info.skinRarity) then
            skinHit = true;
        end;
    else
        skinHit = true;
    end;

    if skinHit then
        table.insert(hitReasons, "Skin - Hit!");
    end;

    local statHit = false;
    if #config.STAND.stat_combo > 0 then
        local actual = {info.strength, info.speed, info.specialty};
        for _, combo in ipairs(config.STAND.stat_combo) do
            if combo[1] == actual[1] and combo[2] == actual[2] and combo[3] == actual[3] then
                statHit = true;
                break;
            end;
        end;
    else
        statHit = true;
    end;

    if statHit then
        table.insert(hitReasons, "Stats - Hit!");
    end;

    if mode == "All" then
        if not (traitHit and skinHit and statHit) then
            return false, nil;
        end;
    else
        if not (traitHit or skinHit or statHit) then
            return false, nil;
        end;
    end;

    return true, table.concat(hitReasons, " | ");
end;

