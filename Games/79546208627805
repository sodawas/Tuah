local function UpdateBossESP()
    -- CLEANUP (entfernt alte/buggy ESPs)
    for mob, esp in pairs(ESP.Bosses) do
        if not mob or not mob.Parent then
            if esp.Highlight then esp.Highlight:Destroy() end
            if esp.Name then esp.Name:Remove() end
            ESP.Bosses[mob] = nil
        end
    end

    -- UPDATE / CREATE
    for _, mob in pairs(workspace.Live:GetChildren()) do
        if mob:IsA("Model") and IsBoss(mob) then

            local root = mob:FindFirstChild("HumanoidRootPart")
                or mob:FindFirstChildWhichIsA("BasePart")

            if root then
                -- CREATE wenn nicht existiert
                if not ESP.Bosses[mob] then
                    ESP.Bosses[mob] = CreateBossESP(mob)
                end

                local esp = ESP.Bosses[mob]

                -- HIGHLIGHT
                if esp.Highlight then
                    esp.Highlight.FillColor = ESPSettings.Boss.Aura.Color
                    esp.Highlight.OutlineColor = ESPSettings.Boss.Aura.OutlineColor
                    esp.Highlight.Enabled = ESPSettings.Boss.Aura.Enabled
                end

                -- SCREEN POSITION
                local pos, vis = WorldToScreen(root.Position)

                -- NAME ESP
                if ESPSettings.Boss.Name.Enabled and vis then
                    esp.Name.Text = mob.Name
                    esp.Name.Color = ESPSettings.Boss.Name.Color
                    esp.Name.Size = ESPSettings.Boss.Name.Size
                    esp.Name.Position = pos
                    esp.Name.Visible = true
                else
                    esp.Name.Visible = false
                end
            end
        end
    end
end

