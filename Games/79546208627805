function LINEAGE:StartAutoStory()
    if storyRunning then return end;
    storyRunning = true;

    storyThread = task.spawn(function()
        while storyRunning do
            task.wait(1);
            if not humanoidrootpart or not humanoid or humanoid.Health <= 0 then
                task.wait(1);
                continue;
            end;

            local quest = self:GetActiveStorylineQuest()
            if not quest then
                task.wait(2.5);
                continue;
            end;

            local questType, target = self:GetQuestType(quest)
  if questType == "Talk" then
    local talkTargets = self:GetTalkObjectivesFromUI()

    if #talkTargets == 0 then
        talkTargets = target
    end

    for _, npcName in ipairs(talkTargets) do
        if not storyRunning then break end

        if not self:IsTalkDone(quest.Name, npcName) then
            self:TalkToNPC(npcName, quest.Name)
        end

        task.wait(0.02)
    end

    task.wait(0.03)


        elseif questType == "Kill" then
            self:KillMobForQuest(quest)
            task.wait(0.1)

            elseif questType == "RaidKill" then
                self:HandleRaidKillQuest(quest, target)
                task.wait(2)
            elseif questType == "Raid" then
                config.RAID.selected = config.RAID.bosses[1]
                getgenv().auto_join_raid = true
                self:AutoJoinRaid()
                self:WaitForQuestComplete(quest.Name, 120)
                getgenv().auto_join_raid = false;
                config.RAID.selected = nil;
                task.wait(2);
            else
                task.wait(5);
            end;
        end;
    end)
end;

function LINEAGE:StopStory()
    storyRunning = false;
    if storyThread then
        task.cancel(storyThread);
        storyThread = nil;
    end;
end;

