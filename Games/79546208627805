function Lineage:GetTarget()
    if not humanoidrootpart then return nil; end;
    local closestBoss = nil;
    local closestMob = nil;
    local bossDistance = math.huge;
    local mobDistance = math.huge;

    for _, model in ipairs(workspace.Live:GetChildren()) do
        if not model:IsA("Model") then continue; end;
        
        local hum = model:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue; end;
        
        if players:GetPlayerFromCharacter(model) then continue; end;

        local root = model:FindFirstChild("HumanoidRootPart");
        if not root then continue; end;

        local nameClean = (model.Name or ""):gsub("%s+", "");
        local distance = (humanoidrootpart.Position - root.Position).Magnitude;

        if config.FARM.selected_boss then
            local cleanBoss = config.FARM.selected_boss:gsub("%s+", "");
            if nameClean:find(cleanBoss) then
                if distance < bossDistance then
                    bossDistance = distance;
                    closestBoss = model;
                end;
            end;
        end;

        for _, mobName in pairs(config.FARM.selected_mobs or {}) do
            if typeof(mobName) == "string" then
                local cleanMob = mobName:gsub("%s+", "")
                if nameClean:find(cleanMob) then
                    if distance < mobDistance then
                        mobDistance = distance;
                        closestMob = model;
                    end;
                end;
            end;
        end;
    end;

    if getgenv().boss_farming and closestBoss then
        return closestBoss;
    end;

    if getgenv().farming and closestMob then
        return closestMob;
    end;

    return closestMob;
end;

