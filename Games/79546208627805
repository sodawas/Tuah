                                );
                            else
                                Label_StandLevel:ChangeText("Stand Level: No data");
                            end;
                        end;
                    end;
                end;
            else
                Label_Stand:ChangeText("Stand: None");
                Label_StandStats:ChangeText("Stand Stats: N/A");
                Label_StandLevel:ChangeText("Stand Level: N/A");
            end;
        end);

        task.wait(0.5);
    end;
end);

