function Lineage:AutoSell()
    local inventoryValue = client.PlayerData.SlotData.Inventory;
    local raw = inventoryValue.Value;
    if raw == "" then return; end;

    local ok, items = pcall(httpservice.JSONDecode, httpservice, raw);
    if not ok then return; end;

    local sellRemote = replicatedstorage.requests.general.SellItem;
    local soldCount = 0;

    for _, item in ipairs(items) do
        if item.ID and not item.Locked then

            if #config.SELL.selected_rarities > 0 then
                local itemRarity = item.Rarity or "Common";
                if not table.find(config.SELL.selected_rarities, itemRarity) then
                    continue; 
                end;
            end;

            sellRemote:FireServer({
                {
                    ["ID"]         = item.ID;
                    ["Pips"]       = item.Pips or {};
                    ["Name"]       = item.Name;
                    ["duplicates"] = 1;
                }
            });
            soldCount += 1;
            task.wait(0.2);
        end;
    end;

    if soldCount > 0 then
        Library:Notify("Sold " .. soldCount .. " item(s)", 3, "Notification");
    end;
end;

