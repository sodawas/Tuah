        local sd = pd.SlotData;
        local xp = sd.Experience.Value;


        Data_Label_Name:ChangeText("Name: " .. tostring(sd.CharacterName.Value));
        Data_Label_Level:ChangeText("Level: " .. tostring(sd.Level.Value) .. " (" .. tostring(xp) .. ")");        
        Data_Label_Elo:ChangeText("Elo: " .. tostring(sd.Elo.Value));
