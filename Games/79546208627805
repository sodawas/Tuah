local function WorldToScreen(pos)
    local vec, visible = camera:WorldToViewportPoint(pos)
    return Vector2.new(vec.X, vec.Y), visible
end

local function CreatePlayerESP()
    local esp = {
        Name = Drawing.new("Text"),
        Box = Drawing.new("Square"),
        Lines = {}
    }

    esp.Name.Center = true
    esp.Name.Outline = true

    esp.Box.Filled = false

    -- mehr lines für skeleton
    for i = 1, 20 do
        local l = Drawing.new("Line")
        table.insert(esp.Lines, l)
    end

    return esp
end


local function UpdatePlayerESP()
    for _, plr in pairs(players:GetPlayers()) do
        if plr ~= client and plr.Character then
            local char = plr.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")

            if root and head then
                if not ESP.Players[plr] then
                    ESP.Players[plr] = CreatePlayerESP()
                end

                local esp = ESP.Players[plr]

                local pos, vis = WorldToScreen(root.Position)
                local headPos, headVis = WorldToScreen(head.Position + Vector3.new(0,1,0))

                -- 📏 DISTANCE
                local distance = (camera.CFrame.Position - root.Position).Magnitude

                -- ❌ zu weit → alles aus
                if distance > 800 or not vis then
                    esp.Name.Visible = false
                    for _, line in pairs(esp.Lines) do
                        line.Visible = false
                    end
                    continue
                end

                -- 👤 NAME + DISTANCE
                if ESPSettings.Player.Name.Enabled and headVis then
                    esp.Name.Text = plr.Name .. " [" .. math.floor(distance) .. "m]"
                    esp.Name.Color = ESPSettings.Player.Name.Color
                    esp.Name.Size = ESPSettings.Player.Name.Size
                    esp.Name.Position = headPos
                    esp.Name.Visible = true
                else
                    esp.Name.Visible = false
                end

                -- 💀 SKELETON (nur wenn nah)
                if ESPSettings.Player.Skeleton.Enabled and distance < 300 then
                    local connections = {
                        {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
                        {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
                        {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
                        {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
                        {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},

                        -- R6 fallback
                        {"Head","Torso"},
                        {"Torso","Left Arm"},{"Left Arm","Left Leg"},
                        {"Torso","Right Arm"},{"Right Arm","Right Leg"}
                    }

                    local index = 1

                    for _, pair in ipairs(connections) do
                        local a = char:FindFirstChild(pair[1])
                        local b = char:FindFirstChild(pair[2])
                        local line = esp.Lines[index]

                        if a and b then
                            local p1, v1 = WorldToScreen(a.Position)
                            local p2, v2 = WorldToScreen(b.Position)

                            if v1 and v2 then
                                line.From = p1
                                line.To = p2
                                line.Color = ESPSettings.Player.Skeleton.Color
                                line.Thickness = ESPSettings.Player.Skeleton.Thickness
                                line.Visible = true
                            else
                                line.Visible = false
                            end
                        else
                            line.Visible = false
                        end

                        index += 1
                    end
                else
                    for _, line in pairs(esp.Lines) do
                        line.Visible = false
                    end
                end
            end
        end
    end
end

