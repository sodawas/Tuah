function Lineage:GetItems()
    local closest;
    local distance = math.huge;

    for i,v in pairs(item_cache) do
        if v and v.Parent then
            local dist = (humanoidrootpart.Position - v.Position).Magnitude;

            if dist < distance then
                distance = dist;
                closest = v;
            end;

        else
            item_cache[i] = nil;
        end;
    end;

    return closest;
end;

function Lineage:CollectItems()
    local item = Lineage:GetItems();
    if not item then return; end;

    local distance = (humanoidrootpart.Position - item.Position).Magnitude;

    local tween = tweenservice:Create(
        humanoidrootpart,
        TweenInfo.new(distance / math.huge, Enum.EasingStyle.Linear),
        {CFrame = item.CFrame + Vector3.new(0,2,0)}
    );
    tween:Play();
    tween.Completed:Wait();

    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
        or item.Parent:FindFirstChildWhichIsA("ProximityPrompt", true);

    if prompt then
        fireproximityprompt(prompt);
    end;
end;

function Lineage:Rejoin()
    game:GetService("TeleportService"):Teleport(game.PlaceId, client);
end;

function Lineage:ServerHop()
    Library:Save();
    local success, result = pcall(function()
        return httpservice:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        ))
    end);

    if success and result and result.data then
        for _, server in ipairs(result.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                local ok, err = pcall(function()
                    teleportservice:TeleportToPlaceInstance(game.PlaceId, server.id, client)
                end);
                if ok then
                    break;
                else
                    warn("Teleport failed: ", err);
                end;
            end;
        end;
    else
        warn("something unexpected happened: ", result);
    end;
end;

function Lineage:ItemsExist()
    for i,v in pairs(item_cache) do
        if v and v.Parent then
            return true;
        else
            item_cache[i] = nil;
        end;
    end;
    return false;
end;

function Lineage:getBoss()
    if not selected_boss then return; end;

    for _,npc in pairs(alive:GetChildren()) do
        if npc:IsA("Model") then
            local hum = npc:FindFirstChild("Humanoid");
            if hum and hum.Health > 0 then
                if string.find(npc.Name, selected_boss) then
                    return npc;
                end;
            end;
        end;
    end;
end;


