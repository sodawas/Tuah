function Lineage:getAlive()
    local mobs = {};

    for _,v in pairs(alive:GetChildren()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            if not players:GetPlayerFromCharacter(v) then
                for _,mob in ipairs(mob_living) do
                    local mob_clean = mob:gsub("%s+", "");
                    if string.find(v.Name, mob_clean) then
                        table.insert(mobs, v);
                        break;
                    end;
                end;
            end;
        end;
    end;

    return mobs;
end;

for _, mob in ipairs(mob_living) do
    table.insert(mob_choices, mob)
end

function Lineage:getMobRoot(mob)
    if mob and mob:IsA("Model") then
        local root = mob:FindFirstChild("HumanoidRootPart");
        return root;
    end;
end;

function Lineage:isMobSelected(name)
    for k,v in pairs(selected_mobs) do
        local mob = typeof(k) == "string" and k or v
        if typeof(mob) == "string" then
            if string.find(name, mob) then
                return mob;
            end;
        end;
    end;

    return nil;
end;

function Lineage:getClosestMob()
    local closest;
    local distance = math.huge;
    local mobs = Lineage:getAlive();

    for _,mob in ipairs(mobs) do
        if Lineage:isMobSelected(mob.Name) then
            local root = Lineage:getMobRoot(mob);

            if root then
                local dist = (humanoidrootpart.Position - root.Position).Magnitude;
                if dist < distance then
                    distance = dist;
                    closest = mob;
                end;
            end;
        end;
    end;

    return closest;
end;

function Lineage:getTargetMob()
    for k,v in pairs(selected_mobs) do
        local mob = typeof(k) == "string" and k or v
        if typeof(mob) ~= "string" then continue; end;
        local closest;
        local distance = math.huge;

        for _,npc in pairs(alive:GetChildren()) do
            if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 then
                if string.find(npc.Name, mob) then
                    local root = npc:FindFirstChild("HumanoidRootPart");

                    if root then
                        local dist = (humanoidrootpart.Position - root.Position).Magnitude;
                        if dist < distance then
                            distance = dist;
                            closest = npc;
                        end;
                    end;
                end;
            end;
        end;

        if closest then
            return closest;
        end;
    end;
end;

function Lineage:tweenToMob(mob)
    if not mob then return; end;

    local root = mob:FindFirstChild("HumanoidRootPart")
    if not root then return; end;

    local padding = 4;
    local behindOffset = root.CFrame.LookVector * -padding;
    local targetPosition = root.Position + behindOffset;
    local targetCFrame = CFrame.new(targetPosition, root.Position);
    local distance = (humanoidrootpart.Position - targetPosition).Magnitude;

    if distance < 1.5 then
        return;
    end;

    local tween = tweenservice:Create(
        humanoidrootpart,
        TweenInfo.new(distance / 40, Enum.EasingStyle.Linear),
        {CFrame = targetCFrame}
    )
    tween:Play()
end;

function Lineage:teleportToMob(mob)
    if not mob then return; end;

    local root = mob:FindFirstChild("HumanoidRootPart");
    if not root then return; end;

    local targetPosition;

    if teleport_position == "Behind" then
        targetPosition = root.Position + (root.CFrame.LookVector * -teleport_offset);

    elseif teleport_position == "Below" then
        targetPosition = root.Position - Vector3.new(0, teleport_offset, 0);

    elseif teleport_position == "Above" then
        targetPosition = root.Position + Vector3.new(0, teleport_offset, 0);
    end;

    humanoidrootpart.CFrame = CFrame.new(targetPosition, root.Position);
end;

