                        or root;

                    if not hit_part then continue; end;

                    pcall(function()
                        if mode == "throw" then
                            local dir = my_root and (root.Position - my_root.Position).Unit or Vector3.new(0,0,1);
                            knife_remotes.RenderKnifeProjectile:FireServer({
                                t0 = workspace:GetServerTimeNow(),
                                x0 = my_root and my_root.Position or root.Position,
                                dir = dir,
                                skinTexture = "",
                                effectId = "",
                                meshId = "",
                                meshScale = Vector3.new(1,1,1),
                                meshTextureId = "",
                                skinId = ""
                            });
                            task.wait(0.05);
                            knife_remotes.KnifeHit:FireServer("throw", hit_part);
                        else
                            knife_remotes.KnifeHit:FireServer("stab", hit_part);
                        end;
                    end);

                    task.wait(getgenv().killaura_delay or 0.1);
                end;
            end;

            task.wait(0.05);
        end;
