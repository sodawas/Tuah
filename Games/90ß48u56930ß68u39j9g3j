                local radius = getgenv().killaura_radius or math.huge;
                local mode = getgenv().killaura_mode or "stab";
                local my_root = my_char and my_char:FindFirstChild("HumanoidRootPart");

                for _, p in ipairs(players:GetPlayers()) do
                    if p == client then continue; end;

                    local char = p.Character;
                    local root = char and char:FindFirstChild("HumanoidRootPart");
                    local is_seeker = char and char:FindFirstChild("SeekerKnife") ~= nil;

                    if not root or is_seeker then continue; end;

                    local dist = my_root and (root.Position - my_root.Position).Magnitude or 0;
                    if dist > radius then continue; end;

                    local hit_part = char:FindFirstChild("HumanoidRootPart")
                        or char:FindFirstChild("Torso")
