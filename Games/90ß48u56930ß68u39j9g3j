    local function updateDrawings()
        local camera = workspace.CurrentCamera;
        if not camera then return; end;

        local my_char = client.Character;
        local my_root = my_char and my_char:FindFirstChild("HumanoidRootPart");
        if not my_root then return; end;

        local esp_names    = getgenv().esp_names or false;
        local esp_dist     = getgenv().esp_distance or false;
        local esp_box      = getgenv().esp_box or false;
        local esp_max      = getgenv().esp_max_distance or 1000;
        local seeker_color = getgenv().esp_seeker_color or Color3.fromRGB(255, 80, 80);
        local hider_color  = getgenv().esp_hider_color or Color3.fromRGB(80, 180, 255);

        local i_am_seeker = isSeeker(client);

        for _, p in ipairs(players:GetPlayers()) do
            if p == client then continue; end;

            local drawings = esp_drawings[p];
            if not drawings then drawings = createDrawings(p); end;

            local target_is_seeker = isSeeker(p);

            local should_show;
            if i_am_seeker then
                should_show = not target_is_seeker and not isDead(p);
            else
                should_show = target_is_seeker;
            end;

            local char = p.Character;
            local root = char and char:FindFirstChild("HumanoidRootPart");

            if not should_show or not root then
                for _, d in pairs(drawings) do d.Visible = false; end;
                continue;
            end;

            local dist = (root.Position - my_root.Position).Magnitude;
            if dist > esp_max then
                for _, d in pairs(drawings) do d.Visible = false; end;
                continue;
            end;

            local screen_pos, on_screen = camera:WorldToViewportPoint(root.Position);
            if not on_screen then
                for _, d in pairs(drawings) do d.Visible = false; end;
                continue;
            end;

            local pos2d = Vector2.new(screen_pos.X, screen_pos.Y);
            local color = target_is_seeker and seeker_color or hider_color;

            drawings.name.Visible = esp_names;
            drawings.name.Text = p.Name;
            drawings.name.Position = pos2d + Vector2.new(0, -32);
            drawings.name.Color = color;

            drawings.distance.Visible = esp_dist;
            drawings.distance.Text = math.round(dist) .. "m";
            drawings.distance.Position = pos2d + Vector2.new(0, -17);
            drawings.distance.Color = Color3.fromRGB(200, 200, 200);

            if esp_box then
                local head_pos = camera:WorldToViewportPoint(root.Position + Vector3.new(0, 2.5, 0));
                local foot_pos = camera:WorldToViewportPoint(root.Position + Vector3.new(0, -3, 0));
                local h = math.abs(head_pos.Y - foot_pos.Y);
                local w = h * 0.5;
                local x = screen_pos.X - w / 2;

                drawings.box_top.From    = Vector2.new(x, head_pos.Y);
                drawings.box_top.To      = Vector2.new(x + w, head_pos.Y);
                drawings.box_bottom.From = Vector2.new(x, foot_pos.Y);
                drawings.box_bottom.To   = Vector2.new(x + w, foot_pos.Y);
                drawings.box_left.From   = Vector2.new(x, head_pos.Y);
                drawings.box_left.To     = Vector2.new(x, foot_pos.Y);
                drawings.box_right.From  = Vector2.new(x + w, head_pos.Y);
                drawings.box_right.To    = Vector2.new(x + w, foot_pos.Y);

                for _, line in pairs({ drawings.box_top, drawings.box_bottom, drawings.box_left, drawings.box_right }) do
                    line.Visible = true;
                    line.Color = color;
                end;
            else
                drawings.box_top.Visible = false;
                drawings.box_bottom.Visible = false;
                drawings.box_left.Visible = false;
                drawings.box_right.Visible = false;
            end;
        end;

        for p, _ in pairs(esp_drawings) do
            if not players:FindFirstChild(p.Name) then
                removeDrawings(p);
            end;
        end;
    end;

    players.PlayerRemoving:Connect(removeDrawings);

    task.spawn(function()
        while true do task.wait(); pcall(updateDrawings); end;
    end);

    local function parsetelemetry(value)
        if not value or value == "" then return; end;

        local phase, hiders, seekers, message = value:match("^(%u+)%s*|%s*hiders=(%d+)%s+seekers=(%d+)%s*|%s*(.+)$");
        if not phase then return; end;

        if phase == "HIDE" and message:find("role reveal") then
            dead_players = {};
            if getgenv().match_log_ref then
                getgenv().match_log_ref:Clear();
            end;
        end;

        local my_char = client.Character;
        local i_am_seeker = my_char and my_char:FindFirstChild("SeekerKnife") ~= nil;

        local role_text;
        if phase == "INTERMISSION" then
            role_text = "Role: ⏳ Lobby";
        elseif i_am_seeker then
            role_text = "Role: 🔪 Seeker";
        else
            role_text = "Role: 🎨 Hider";
        end;

        if getgenv().role_label_ref then
            getgenv().role_label_ref:ChangeText(role_text .. "  |  👥 H:" .. hiders .. " S:" .. seekers);
        end;

        local icon = "";
        if phase == "ROUND" then icon = "🔍 ";
        elseif phase == "HIDE" then icon = "🎨 ";
        elseif phase == "RESOLVE" then icon = "🏁 ";
        elseif phase == "INTERMISSION" then icon = "⏳ "; end;

        if getgenv().match_log_ref then
            getgenv().match_log_ref:AddEntry(icon .. message);
        end;
    end;

    if telemetry then
        parsetelemetry(telemetry.Value);
        telemetry.Changed:Connect(parsetelemetry);
    end;
end;

