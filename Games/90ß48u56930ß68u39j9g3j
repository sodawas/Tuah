--:: Character Handler ::--
type Player = {
    name: string;
    character: any;
    root: any;
    humanoid: any;
};

local character = {};
character.__index = character;

function character.new(): Player
    local self = setmetatable({}, character);
    self.name = client.Name;
    self.character = client.Character or client.CharacterAdded:Wait();
    self.root = self.character:WaitForChild("HumanoidRootPart");
    self.humanoid = self.character:FindFirstChildOfClass("Humanoid");

    client.CharacterAdded:Connect(function(new)
        self.character = new;
        self.root = new:WaitForChild("HumanoidRootPart");
        self.humanoid = new:FindFirstChildOfClass("Humanoid");
    end);
    return self;
end;

function character:getPosition()
    if not self.root then 
        return nil; 
    end;
    return self.root.Position;
end;

function character:isAlive(): boolean
    if not self.humanoid then 
        return false; 
    end;
    return self.humanoid.Health > 0;
end;

function character:teleportTo(position: Vector3)
    local ok, no = pcall(function()
        self.root.CFrame = CFrame.new(position)
    end)
    if not ok then print("teleport error: " .. tostring(no)) end;
end;

