local function getBuild(): string
    local ok, response = pcall(function()
        return request({
            Url    = REPO .. "build.txt",
            Method = "GET"
        })
    end);

    if not ok or not response or response.StatusCode ~= 200 then
        return "🔴 Unknown";
    end;

    local body = tostring(response.Body or "")
    if body:find("Down") then
        return "🔴 Down";
    end;
    return "🟢 " .. body:gsub("%s+", "");
end;

