local rainbow_mode; rainbow_mode = Sections.Themes:CreateToggle({
    Text = "Rainbow Mode";
    Subtext = "";
    Alignment = "Left";
    Default = false;
    Callback = function(Value)
        getgenv().rainbow_mode = Value;
        if Value then
            task.spawn(function()
                local t = 0;
                while getgenv().rainbow_mode do
                    t = (t + 0.002) % 1;

                    if not Library.Themes["Custom"] then
                        Library.Themes["Custom"] = {};
                        for k, v in pairs(Library.Themes["Default"]) do
                            Library.Themes["Custom"][k] = v;
                        end;
                    end;

                    local primary = Color3.fromHSV(t, 1, 1);
                    local secondary = Color3.fromHSV((t + 0.05) % 1, 0.7, 0.8);
                    local hover = Color3.fromHSV((t + 0.02) % 1, 0.8, 0.6);

                    Library.Themes["Custom"]["Highlight"] = primary;
                    Library.Themes["Custom"]["Selected"] = secondary;
                    Library.Themes["Custom"]["Hover"] = hover;
                    Library.Theme = "Custom";
                    task.wait();
                end;
            end);
        else
            Library.Theme = "Default";
        end;
    end;
    Flag = "rainbow_mode";
})

