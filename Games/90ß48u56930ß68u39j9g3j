local hide_maid = maid.new();

local EXCLUDED_NAMES = {
    ["CityBorder"] = true,
    ["CityCarBorder"] = true,
    ["SpawnPoints"] = true,
};

local function getHideSpots()
    local map = workspace:FindFirstChild("ActiveMap");
    if not map then return {}; end;

    local spots = {};
    for _, obj in ipairs(map:GetChildren()) do
        if obj:IsA("Model") and not EXCLUDED_NAMES[obj.Name] then
            local ok, cf, size = pcall(function() return obj:GetBoundingBox(); end);
            if ok then
                local max_dim = math.max(size.X, size.Y, size.Z);
                local min_dim = math.min(size.X, size.Y, size.Z);
                if max_dim <= 10 and min_dim >= 1.5 then
                    table.insert(spots, { model = obj, cf = cf, size = size });
                end;
            end;
        end;
    end;
    return spots;
end;

local function isSeekerNearby(radius)
    local my_root = player.root;
    if not my_root then return false; end;

    for _, p in ipairs(players:GetPlayers()) do
        if p ~= client then
            local char = p.Character;
            local root = char and char:FindFirstChild("HumanoidRootPart");
            if root then
                local is_seeker = char:FindFirstChild("SeekerKnife") ~= nil;
                if is_seeker then
                    local dist = (root.Position - my_root.Position).Magnitude;
                    if dist <= radius then
                        return true, p.Name, dist;
                    end;
                end;
            end;
        end;
    end;
    return false;
end;

local function findGoodHideSpot(spots, avoid_position)
    if #spots == 0 then return nil; end;
    local shuffled = {};

    for i, v in ipairs(spots) do shuffled[i] = v; end;
    for i = #shuffled, 2, -1 do
        local j = math.random(i);
        shuffled[i], shuffled[j] = shuffled[j], shuffled[i];
    end;

    for _, spot in ipairs(shuffled) do
        local cf, size = spot.cf, spot.size;

        if avoid_position then
            local dist_from_avoid = (cf.Position - avoid_position).Magnitude;
            if dist_from_avoid < 15 then continue; end;
        end;

        local radius = math.max(size.X, size.Z) / 2 + 1.5;
        local angles = { 0, 90, 180, 270, 45, 135, 225, 315 };
        for _, angle_offset in ipairs(angles) do
            local rad = math.rad(angle_offset);
            local dir = Vector3.new(math.cos(rad), 0, math.sin(rad));
            local test_pos = cf.Position + dir * radius;
            local params = RaycastParams.new();
            params.FilterType = Enum.RaycastFilterType.Exclude;
            params.FilterDescendantsInstances = { player.character };

            local down_result = workspace:Raycast(test_pos + Vector3.new(0, 10, 0), Vector3.new(0, -50, 0), params);
            if down_result then
                local floor_pos = down_result.Position + Vector3.new(0, 3, 0);
                local clear_check = workspace:Raycast(floor_pos, dir * -1.5, params);
                if not clear_check then
                    return CFrame.new(floor_pos, cf.Position);
                end;
            end;
        end;
    end;
    return nil;
end;

local function teleportToHideSpot(avoid_position)
    local spots = getHideSpots();
    local target_cf = findGoodHideSpot(spots, avoid_position);

    if target_cf and player.root then
        player:teleportTo(target_cf.Position);
        return true;
    end;
    return false;
end;

