function BITE:Entry()
    if typeof(BITE) == "table" and table.find(PLACE_ID, game.PlaceId) and self:Data() then 
        print(" -- Check Successful -- " .. " | " .. tostring(os.date()));
    else
        print(" -- Check Failed -- ");
