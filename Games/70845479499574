end;

function BITE:Data()
    local success, response = pcall(function()
        return request({ Url = GIT, Method = "GET" })
    end)

    if (not success) or not response or response.StatusCode ~= 200 then
        self:ClientKick("HTTPGET: Response Failed")
        return false;
    end;

    local body = response.Body;
    local parsed, env = pcall(function()
        local chunk = loadstring("return " .. body);
        return chunk()
    end);

    if not parsed or not env then
        self:ClientKick("HTTPGET: Parse Failed")
        return false;
    end;

    if env.BUILD ~= "Testing" and env.BUILD ~= "Online" then
        self:ClientKick("Lotus is currently not available, for more Information check our Discord!")
        return false;
    end;
    return true;
end;

function BITE:ClientKick(msg)
    local kick = 0;
    msg = msg or "//";

    if typeof(msg) == "string" then
        return client:Kick(msg);
    end;
end;

function BITE:Build()
    local success, response = pcall(function()
        return request({
            Url = GIT,
            Method = "GET"
        })
    end)

    if not success or not response or response.StatusCode ~= 200 then
        return "Unknown"
    end;

    local body = tostring(response.Body or "");

    if string.find(body, "Down") then
        return "Unknown"
    end;

    return "Updated";
end;

function BITE:getGame()
    local market_service = game:GetService("MarketplaceService");
    local succ, m_info = pcall(market_service.GetProductInfo, market_service, game.PlaceId);
    return succ and m_info.Name or "N/A";
end;

function NIGHT:Get_Map()
    if not gameFolder then
        return "Lobby";
    end;

    local currentMap = gameFolder:FindFirstChild("CURRENTMAP");
    if not currentMap then
        return "Lobby";
    end;

    if currentMap:IsA("StringValue") then
        local value = tostring(currentMap.Value or "");
        if value ~= "" then
            return value;
        end;
    end;
    return "Lobby";
end;

function NIGHT:Get_Region()
    local region = gameFolder:FindFirstChild("Region");

    if not region then 
        return "--";
    end;

    if region:IsA("StringValue") then 
        local val = tostring(region.Value or "");
        if val ~= "" then 
            return val;
        end;
    end;
    return ""
end;

function NIGHT:Get_Killer()
    local playersFolder = workspace:FindFirstChild("PLAYERS");
    if not playersFolder then
        return "None";
    end;

    local killerFolder = playersFolder:FindFirstChild("KILLER");
    if not killerFolder then
        return "None";
    end;

    for _, model in ipairs(killerFolder:GetChildren()) do
        if model:IsA("Model") then
            local killerCharacter = model:GetAttribute("Character");

            if typeof(killerCharacter) == "string" and killerCharacter ~= "" then
                return killerCharacter;
            end;
            return model.Name;
        end;
    end;
    return "None";
end;


