local function IsInGame()
    local playersFolder = workspace:FindFirstChild("PLAYERS")
    local get_char = client.Character

    if not playersFolder or not get_char or not get_char.Parent then
        return false;
    end;
    local parent = get_char.Parent
    if parent == playersFolder:FindFirstChild("LOBBY") then
        return false;
    end;
    if parent == playersFolder:FindFirstChild("ALIVE") then
        return true;
    end;
    if parent == playersFolder:FindFirstChild("KILLER") then
        return true;
    end;
    return false;
end;

local function DestroyESP(esp)
    if not esp then return; end;

    pcall(function()
        if esp.Highlight then
            esp.Highlight:Destroy()
        end;
    end);

    pcall(function()
        if esp.Name then
            esp.Name:Remove()
        end;
    end);

    pcall(function()
        if esp.HealthText then
            esp.HealthText:Remove()
        end;
    end);

    pcall(function()
        if esp.SkeletonLines then
            for _, line in ipairs(esp.SkeletonLines) do
                line:Remove()
            end;
        end;
    end);
end;

local function HideESP(esp, hasHealth)
    if not esp then return; end;

    if esp.Highlight then
        esp.Highlight.Enabled = false;
    end;

    if esp.Name then
        esp.Name.Visible = false;
    end;

    if hasHealth and esp.HealthText then
        esp.HealthText.Visible = false;
    end;

    if esp.SkeletonLines then
        for _, line in ipairs(esp.SkeletonLines) do
            line.Visible = false;
        end;
    end;
end;

local function GetCharacterParts(model)
    if not model or not model:IsA("Model") then
        return nil;
    end;

    local humanoid = model:FindFirstChildOfClass("Humanoid");
    local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("RootPart") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso") or model.PrimaryPart
    local head = model:FindFirstChild("Head") or model:FindFirstChild("Hitbox") or model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("RootPart") or model.PrimaryPart

    if not head then
        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("BasePart") then
                local n = v.Name:lower()
                if n:find("head") or n:find("hitbox") then
                    head = v;
                    break;
                end;
            end;
        end;
    end;

    local upperTorso = model:FindFirstChild("UpperTorso");
    local lowerTorso = model:FindFirstChild("LowerTorso");
    local torso = model:FindFirstChild("Torso");
    local leftUpperArm = model:FindFirstChild("LeftUpperArm");
    local leftLowerArm = model:FindFirstChild("LeftLowerArm");
    local leftHand = model:FindFirstChild("LeftHand");
    local rightUpperArm = model:FindFirstChild("RightUpperArm");
    local rightLowerArm = model:FindFirstChild("RightLowerArm");
    local rightHand = model:FindFirstChild("RightHand");
    local leftArm = model:FindFirstChild("Left Arm");
    local rightArm = model:FindFirstChild("Right Arm");
    local leftUpperLeg = model:FindFirstChild("LeftUpperLeg");
    local leftLowerLeg = model:FindFirstChild("LeftLowerLeg");
    local leftFoot = model:FindFirstChild("LeftFoot");
    local rightUpperLeg = model:FindFirstChild("RightUpperLeg");
    local rightLowerLeg = model:FindFirstChild("RightLowerLeg");
    local rightFoot = model:FindFirstChild("RightFoot");
    local leftLeg = model:FindFirstChild("Left Leg");
    local rightLeg = model:FindFirstChild("Right Leg");

    return {
        Head = head,
        Humanoid = humanoid,
        Root = root,

        UpperTorso = upperTorso,
        LowerTorso = lowerTorso,
        Torso = torso,

        LeftUpperArm = leftUpperArm,
        LeftLowerArm = leftLowerArm,
        LeftHand = leftHand,

        RightUpperArm = rightUpperArm,
        RightLowerArm = rightLowerArm,
        RightHand = rightHand,

        LeftArm = leftArm,
        RightArm = rightArm,

        LeftUpperLeg = leftUpperLeg,
        LeftLowerLeg = leftLowerLeg,
        LeftFoot = leftFoot,

        RightUpperLeg = rightUpperLeg,
        RightLowerLeg = rightLowerLeg,
        RightFoot = rightFoot,

        LeftLeg = leftLeg,
        RightLeg = rightLeg,
    }
end

local function CreateESP(target, isKiller)
    local model = target
    if typeof(target) == "Instance" and target:IsA("Player") then
        model = target.Character;
    end;

    if not model or not model:IsA("Model") then
        return nil;
    end;

    local cfg = isKiller and ESPSettings.Killer or ESPSettings.Survivor;

    local highlight = Instance.new("Highlight")
    highlight.Name = "LotusESP_Aura"
    highlight.FillColor = cfg.Aura.Color
    highlight.OutlineColor = cfg.Aura.OutlineColor
    highlight.FillTransparency = 0.45
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = false
    highlight.Adornee = model
    highlight.Parent = model

    local esp = {
        Target = target,
        Model = model,
        Highlight = highlight,
        Name = Drawing.new("Text"),
        HealthText = Drawing.new("Text"),
        SkeletonLines = {}
    }

    esp.Name.Size = 16
    esp.Name.Center = true
    esp.Name.Outline = true
    esp.Name.Color = cfg.Name.Color
    esp.Name.Visible = false
    esp.Name.Font = 2

    esp.HealthText.Size = 14
    esp.HealthText.Center = true
    esp.HealthText.Outline = true
    esp.HealthText.Visible = false
    esp.HealthText.Font = 2

    for i = 1, 16 do
        local line = Drawing.new("Line")
        line.Color = cfg.Skeleton.Color;
        line.Thickness = 1.8;
        line.Visible = false;
        table.insert(esp.SkeletonLines, line);
    end;

    return esp;
end;

function UpdateGenerators()
    local validGenerators = {};
    local mapsFolder = workspace:FindFirstChild("MAPS");
    local gameMap = mapsFolder and mapsFolder:FindFirstChild("GAME MAP");
    local generatorsFolder = gameMap and gameMap:FindFirstChild("Generators");

    if generatorsFolder then
        for _, gen in ipairs(generatorsFolder:GetChildren()) do
            if gen:IsA("Model") or gen:IsA("BasePart") then
                validGenerators[gen] = true

                if not GeneratorESP[gen] then
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "LotusESP_GeneratorAura"
                    highlight.FillColor = ESPSettings.Generator.Aura.Color
                    highlight.OutlineColor = ESPSettings.Generator.Aura.OutlineColor
                    highlight.FillTransparency = 0.45
                    highlight.OutlineTransparency = 0
                    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    highlight.Enabled = false
                    highlight.Adornee = gen
                    highlight.Parent = gen

                    local text = Drawing.new("Text")
                    text.Size = 16
                    text.Center = true
                    text.Outline = true
                    text.Color = ESPSettings.Generator.Name.Color
                    text.Visible = false
                    text.Font = 2

                    GeneratorESP[gen] = {
                        Highlight = highlight,
                        Name = text
                    }
                end;

                local esp = GeneratorESP[gen];
                local part = nil;

                if gen:IsA("BasePart") then
                    part = gen;
                else
                    part = gen.PrimaryPart or gen:FindFirstChild("Main") or gen:FindFirstChild("Hitbox") or gen:FindFirstChild("RootPart") or gen:FindFirstChildWhichIsA("BasePart")

                    if not part then
                        for _, v in ipairs(gen:GetDescendants()) do
                            if v:IsA("BasePart") then
                                part = v;
                                break;
                            end;
                        end;
                    end;
                end;

                if part then
                    local pos, onScreen = camera:WorldToViewportPoint(part.Position + Vector3.new(0, 2.5, 0));
                    local distance = (camera.CFrame.Position - part.Position).Magnitude;

                    esp.Highlight.FillColor = ESPSettings.Generator.Aura.Color;
                    esp.Highlight.OutlineColor = ESPSettings.Generator.Aura.OutlineColor;
                    esp.Highlight.Enabled = ESPSettings.Generator.Aura.Enabled;

                    esp.Name.Color = ESPSettings.Generator.Name.Color;
                    if ESPSettings.Generator.Name.Enabled and onScreen then
                        esp.Name.Position = Vector2.new(pos.X, pos.Y);
                        esp.Name.Text = string.format("Generator [%.0f]", distance);
                        esp.Name.Visible = true;
                    else
                        esp.Name.Visible = false;
                    end
                else
                    esp.Highlight.Enabled = false;
                    esp.Name.Visible = false;
                end;
            end;
        end;
    end;

    for gen, esp in pairs(GeneratorESP) do
        if not validGenerators[gen] then
            pcall(function()
                if esp.Highlight then
                    esp.Highlight:Destroy()
                end
            end)
            pcall(function()
                if esp.Name then
                    esp.Name:Remove()
                end
            end)

            GeneratorESP[gen] = nil;
        end;
    end;
end;

local function WorldToScreen(pos)
    local vec, visible = camera:WorldToViewportPoint(pos);
    return Vector2.new(vec.X, vec.Y), visible;
end;

local function DrawLine(line, p1, p2)
    local a, aVis = WorldToScreen(p1);
    local b, bVis = WorldToScreen(p2);

    if aVis and bVis then
        line.From = a;
        line.To = b;
        line.Visible = true;
    else
        line.Visible = false;
    end;
end;

local function UpdateSurvivorSkeleton(esp, model)
    if not ESPSettings.Survivor.Skeleton.Enabled then
        for _, line in ipairs(esp.SkeletonLines) do
            line.Visible = false;
        end;
        return;
    end;

    local parts = GetCharacterParts(model)
    if not parts or not parts.Head or not parts.Root then
        for _, line in ipairs(esp.SkeletonLines) do
            line.Visible = false;
        end;
        return;
    end;

    local lines = esp.SkeletonLines
    for _, line in ipairs(lines) do
        line.Visible = false;
    end;

    local idx = 1
    local function nextLine(a, b)
        if not a or not b or not lines[idx] then
            idx += 1;
            return;
        end;
        DrawLine(lines[idx], a.Position, b.Position);
        idx += 1;
    end;

    if parts.UpperTorso and parts.LowerTorso then
        nextLine(parts.Head, parts.UpperTorso);
        nextLine(parts.UpperTorso, parts.LowerTorso);
        nextLine(parts.LowerTorso, parts.Root);

        if parts.LeftUpperArm then
            nextLine(parts.UpperTorso, parts.LeftUpperArm);
            if parts.LeftLowerArm then
                nextLine(parts.LeftUpperArm, parts.LeftLowerArm);
                if parts.LeftHand then
                    nextLine(parts.LeftLowerArm, parts.LeftHand);
                end;
            end;
        end;

        if parts.RightUpperArm then
            nextLine(parts.UpperTorso, parts.RightUpperArm);
            if parts.RightLowerArm then
                nextLine(parts.RightUpperArm, parts.RightLowerArm);
                if parts.RightHand then
                    nextLine(parts.RightLowerArm, parts.RightHand);
                end;
            end;
        end;

        if parts.LeftUpperLeg then
            nextLine(parts.LowerTorso, parts.LeftUpperLeg);
            if parts.LeftLowerLeg then
                nextLine(parts.LeftUpperLeg, parts.LeftLowerLeg);
                if parts.LeftFoot then
                    nextLine(parts.LeftLowerLeg, parts.LeftFoot);
                end;
            end;
        end;

        if parts.RightUpperLeg then
            nextLine(parts.LowerTorso, parts.RightUpperLeg);
            if parts.RightLowerLeg then
                nextLine(parts.RightUpperLeg, parts.RightLowerLeg);
                if parts.RightFoot then
                    nextLine(parts.RightLowerLeg, parts.RightFoot);
                end;
            end;
        end;

    elseif parts.Torso then
        nextLine(parts.Head, parts.Torso);
        nextLine(parts.Torso, parts.Root);

        if parts.LeftArm then
            nextLine(parts.Torso, parts.LeftArm);
        end;

        if parts.RightArm then
            nextLine(parts.Torso, parts.RightArm);
        end;

        if parts.LeftLeg then
            nextLine(parts.Root, parts.LeftLeg);
        end;

        if parts.RightLeg then
            nextLine(parts.Root, parts.RightLeg);
        end;
    else
        nextLine(parts.Head, parts.Root);
    end;
end;

local function UpdateKillerSkeleton(esp, model)
    if not ESPSettings.Killer.Skeleton.Enabled then
        for _, line in ipairs(esp.SkeletonLines) do
            line.Visible = false;
        end;
        return;
    end;

    local parts = GetCharacterParts(model);
    if not parts or not parts.Root then
        for _, line in ipairs(esp.SkeletonLines) do
            line.Visible = false;
        end;
        return;
    end;

    local lines = esp.SkeletonLines
    for _, line in ipairs(lines) do
        line.Visible = false;
    end;

    if parts.UpperTorso or parts.Torso then
        local idx = 1
        local function nextLine(a, b)
            if not a or not b or not lines[idx] then
                idx += 1
                return
            end
            DrawLine(lines[idx], a.Position, b.Position)
            idx += 1
        end

        if parts.UpperTorso and parts.LowerTorso and parts.Head then
            nextLine(parts.Head, parts.UpperTorso)
            nextLine(parts.UpperTorso, parts.LowerTorso)
            nextLine(parts.LowerTorso, parts.Root)

            if parts.LeftUpperArm then
                nextLine(parts.UpperTorso, parts.LeftUpperArm)
                if parts.LeftLowerArm then
                    nextLine(parts.LeftUpperArm, parts.LeftLowerArm)
                    if parts.LeftHand then
                        nextLine(parts.LeftLowerArm, parts.LeftHand)
                    end
                end
            end

            if parts.RightUpperArm then
                nextLine(parts.UpperTorso, parts.RightUpperArm)
                if parts.RightLowerArm then
                    nextLine(parts.RightUpperArm, parts.RightLowerArm)
                    if parts.RightHand then
                        nextLine(parts.RightLowerArm, parts.RightHand)
                    end
                end
            end

            if parts.LeftUpperLeg then
                nextLine(parts.LowerTorso, parts.LeftUpperLeg)
                if parts.LeftLowerLeg then
                    nextLine(parts.LeftUpperLeg, parts.LeftLowerLeg)
                    if parts.LeftFoot then
                        nextLine(parts.LeftLowerLeg, parts.LeftFoot)
                    end
                end
            end

            if parts.RightUpperLeg then
                nextLine(parts.LowerTorso, parts.RightUpperLeg)
                if parts.RightLowerLeg then
                    nextLine(parts.RightUpperLeg, parts.RightLowerLeg)
                    if parts.RightFoot then
                        nextLine(parts.RightLowerLeg, parts.RightFoot)
                    end;
                end;
            end;
        return;
        elseif parts.Torso and parts.Head then
            nextLine(parts.Head, parts.Torso)
            nextLine(parts.Torso, parts.Root)

            if parts.LeftArm then
                nextLine(parts.Torso, parts.LeftArm)
            end
            if parts.RightArm then
                nextLine(parts.Torso, parts.RightArm)
            end
            if parts.LeftLeg then
                nextLine(parts.Root, parts.LeftLeg)
            end
            if parts.RightLeg then
                nextLine(parts.Root, parts.RightLeg)
            end

            return;
        end;
    end;

    local hitbox = model:FindFirstChild("Hitbox");
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("RootPart");

    if hitbox and hrp then
        local top = hitbox.Position
        local mid = hrp.Position
        local right = hrp.CFrame.RightVector
        local up = hrp.CFrame.UpVector
        local look = hrp.CFrame.LookVector
        local shoulderBase = top - up * 0.7
        local hipBase = mid - up * 0.5
        local leftShoulder = shoulderBase - right * 1.3
        local rightShoulder = shoulderBase + right * 1.3
        local leftHand = shoulderBase - right * 2.2 - up * 1.3
        local rightHand = shoulderBase + right * 2.2 - up * 1.3
        local leftHip = hipBase - right * 0.7
        local rightHip = hipBase + right * 0.7
        local leftFoot = hipBase - right * 0.7 - up * 2.7
        local rightFoot = hipBase + right * 0.7 - up * 2.7

        DrawLine(lines[1], top, mid)
        DrawLine(lines[2], top, leftShoulder)
        DrawLine(lines[3], leftShoulder, leftHand)
        DrawLine(lines[4], top, rightShoulder)
        DrawLine(lines[5], rightShoulder, rightHand)
        DrawLine(lines[6], mid, leftHip)
        DrawLine(lines[7], leftHip, leftFoot)
        DrawLine(lines[8], mid, rightHip)
        DrawLine(lines[9], rightHip, rightFoot)

        for i = 10, #lines do
            lines[i].Visible = false;
        end;
    else
        if parts.Head and parts.Root then
            DrawLine(lines[1], parts.Head.Position, parts.Root.Position);
        else
            for _, line in ipairs(lines) do
                line.Visible = false;
            end;
        end;
    end;
end;

local function UpdateSurvivorESP(model, espTable, key, displayName)
    if not model or not model:IsA("Model") then
        return;
    end;

    if not espTable[key] then
        espTable[key] = CreateESP(model, false);
    end;

    local esp = espTable[key];
    if not esp then return; end;

    esp.Model = model
    if esp.Highlight then
        esp.Highlight.Adornee = model;
    end;

    local parts = GetCharacterParts(model)
    if not parts or not parts.Root or not parts.Head then
        HideESP(esp, true)
        return;
    end;

    local rootVec, onScreen = camera:WorldToViewportPoint(parts.Root.Position)
    local headVec = camera:WorldToViewportPoint(parts.Head.Position + Vector3.new(0, 0.8, 0))

    if ESPSettings.Survivor.Aura.Enabled then
        esp.Highlight.Enabled = true;
    else
        esp.Highlight.Enabled = false;
    end;

    if not onScreen then
        HideESP(esp, true)
        return;
    end;

    local distance = (camera.CFrame.Position - parts.Root.Position).Magnitude

    if ESPSettings.Survivor.Name.Enabled then
        esp.Name.Position = Vector2.new(headVec.X, headVec.Y - 28)
        esp.Name.Text = string.format("%s [%.0f]", displayName, distance)
        esp.Name.Visible = true
    else
        esp.Name.Visible = false
    end

    if ESPSettings.Survivor.Health.Enabled and parts.Humanoid and parts.Humanoid.MaxHealth > 0 then
        local hp = math.floor((parts.Humanoid.Health / parts.Humanoid.MaxHealth) * 100)
        esp.HealthText.Text = hp .. "%"
        esp.HealthText.Position = Vector2.new(rootVec.X, rootVec.Y + 35)
        esp.HealthText.Color = Color3.fromHSV(math.clamp(hp / 100, 0, 1) * 0.33, 1, 1)
        esp.HealthText.Visible = true
    else
        esp.HealthText.Visible = false
    end

    UpdateSurvivorSkeleton(esp, model)
end

local function UpdateKillerESP(model, espTable, key, displayName)
    if not model or not model:IsA("Model") then
        return;
    end;

    if not espTable[key] then
        espTable[key] = CreateESP(model, true);
    end;

    local esp = espTable[key];
    if not esp then return; end;

    esp.Model = model
    if esp.Highlight then
        esp.Highlight.Adornee = model;
    end;

    local parts = GetCharacterParts(model)
    if not parts or not parts.Root then
        HideESP(esp, false)
        return;
    end;

    local headAnchor = parts.Head or parts.Root
    local rootVec, onScreen = camera:WorldToViewportPoint(parts.Root.Position)
    local headVec = camera:WorldToViewportPoint(headAnchor.Position + Vector3.new(0, 0.8, 0))

    if ESPSettings.Killer.Aura.Enabled then
        esp.Highlight.Enabled = true;
    else
        esp.Highlight.Enabled = false;
    end;

    if not onScreen then
        HideESP(esp, false)
        return;
    end;

    local distance = (camera.CFrame.Position - parts.Root.Position).Magnitude;

    if ESPSettings.Killer.Name.Enabled then
        esp.Name.Position = Vector2.new(headVec.X, headVec.Y - 28)
        esp.Name.Text = string.format("%s [%.0f]", displayName, distance)
        esp.Name.Visible = true;
    else
        esp.Name.Visible = false;
    end;

    UpdateKillerSkeleton(esp, model);
end;

local function CleanupESP(espTable, validKeys, hasHealth)
    for key, esp in pairs(espTable) do
        if not validKeys[key] then
            HideESP(esp, hasHealth)
            local model = esp.Model
            if not model or not model.Parent then
                DestroyESP(esp)
                espTable[key] = nil;
            end;
        end;
    end;
end;

local function UpdateESP()
    if not IsInGame() then
        for key, esp in pairs(SurvivorESP) do
            DestroyESP(esp)
            SurvivorESP[key] = nil
        end;

        for key, esp in pairs(KillerESP) do
            DestroyESP(esp)
            KillerESP[key] = nil
        end;

        for gen, esp in pairs(GeneratorESP) do
            pcall(function()
                if esp.Highlight then
                    esp.Highlight:Destroy()
                end
            end)

            pcall(function()
                if esp.Name then
                    esp.Name:Remove()
                end
            end)

            GeneratorESP[gen] = nil;
        end
        return;
    end;

    local playersFolder = workspace:FindFirstChild("PLAYERS")
    if not playersFolder then
        return;
    end;

    local validSurvivors = {};
    local validKillers = {};

    local aliveFolder = playersFolder:FindFirstChild("ALIVE")
    if aliveFolder then
        for _, model in ipairs(aliveFolder:GetChildren()) do
            if model:IsA("Model") then
                local plr = game.Players:GetPlayerFromCharacter(model)

                if plr ~= client then
                    local key = plr or model;
                    local displayName = plr and plr.Name or model.Name;

                    validSurvivors[key] = true;
                    UpdateSurvivorESP(model, SurvivorESP, key, displayName);
                end;
            end;
        end;
    end;

    local killerFolder = playersFolder:FindFirstChild("KILLER")
    if killerFolder then
        for _, model in ipairs(killerFolder:GetChildren()) do
            if model:IsA("Model") then
                if model ~= character then
                    local plr = game.Players:GetPlayerFromCharacter(model);
                    local key = plr or model;
                    local displayName = plr and plr.Name or model.Name;

                    validKillers[key] = true;
                    UpdateKillerESP(model, KillerESP, key, displayName);
                end;
            end;
        end;
    end;

    UpdateGenerators();
    CleanupESP(SurvivorESP, validSurvivors, true);
    CleanupESP(KillerESP, validKillers, false);
end;

